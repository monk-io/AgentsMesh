load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "auth",
    srcs = ["token.go"],
    importpath = "github.com/anthropics/agentsmesh/relay/internal/auth",
    visibility = ["//relay:__subpackages__"],
    deps = ["@com_github_golang_jwt_jwt_v5//:jwt"],
)

alias(
    name = "go_default_library",
    actual = ":auth",
    visibility = ["//relay:__subpackages__"],
)

go_test(
    name = "auth_test",
    srcs = ["token_test.go"],
    embed = [":auth"],
    deps = ["@com_github_golang_jwt_jwt_v5//:jwt"],
)
