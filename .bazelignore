# Paths Bazel's workspace scanner should skip. Keeps `bazel query //...`
# and `bazel build //...` from walking into generated / cached trees.
node_modules
target
clients/core/target
clients/core/ios-framework
clients/core/crates/node-bridge/node_modules
clients/ios/Packages/AgentsMeshCore/Sources/AgentsMeshCoreFFI/AgentsMeshCore.xcframework
clients/ios/AgentsMesh.xcodeproj
clients/ios/DerivedData
clients/ios/Packages/AgentsMeshCore/.build
clients/ios/Packages/AgentsMeshFeatures/.build
clients/web/.next
clients/web-admin/.next
clients/desktop/dist
clients/desktop/node_modules
packages/electron-adapter/node_modules
packages/service-interface/node_modules
packages/service-runtime/node_modules
clients/web/e2e-playwright/node_modules
clients/desktop/e2e/node_modules
# Swift Package Manager checkout — `swift-syntax` ships its own
# `//utils/bazel:...` references that don't resolve in this workspace,
# breaking `bazel build //...` target expansion. SwiftPM deps are fed
# into Bazel via `rules_swift_package_manager`, not by walking this
# tree.
third_party/swift/.build
.git
.claude
