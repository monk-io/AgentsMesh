// go.work — unifies AgentsMesh's Go modules so Bazel + gazelle can resolve
// cross-module imports (backend → proto, backend → agentfile, runner → proto)
// without per-module `replace` directives.
//
// Listed modules:
//   backend/    — REST/gRPC API server
//   runner/     — pod orchestration daemon
//   relay/      — WebSocket relay service
//   agentfile/  — AgentFile DSL parser
//   proto/      — gRPC schema; Bazel `go_proto_library` writes the
//                  generated `.pb.go` into proto/gen/ at lint/build time
//                  (gitignored — see proto/.gitignore).
go 1.25.0

use (
	./agentfile
	./backend
	./proto
	./relay
	./runner
)
