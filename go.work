// go.work — unifies AgentsMesh's Go modules so Bazel + gazelle can resolve
// cross-module imports (backend → agentfile, runner) without per-module
// `replace` directives.
//
// Listed modules:
//   backend/    — REST/gRPC API server
//   runner/     — pod orchestration daemon
//   relay/      — WebSocket relay service
//   agentfile/  — AgentFile DSL parser
//
// (proto/ used to be a Go module hosting buf-generated `.pb.go`; now Bazel
// generates protobuf stubs on the fly via `//proto/runner/v1:runner_go_proto`,
// so no Go module wrapper is needed — `runner.proto` is the only thing that
// actually lives on disk.)
go 1.25.0

use (
	./agentfile
	./backend
	./relay
	./runner
)
