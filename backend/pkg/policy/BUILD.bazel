load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "policy",
    srcs = [
        "definitions.go",
        "policy.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/pkg/policy",
    visibility = ["//visibility:public"],
)

alias(
    name = "go_default_library",
