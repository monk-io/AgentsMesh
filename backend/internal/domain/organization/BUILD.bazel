load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "organization",
    srcs = [
        "organization.go",
        "repository.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/domain/organization",
    visibility = ["//backend:__subpackages__"],
    deps = ["//backend/internal/domain/user"],
)

alias(
    name = "go_default_library",
    actual = ":organization",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "organization_test",
    srcs = ["organization_test.go"],
    embed = [":organization"],
)
