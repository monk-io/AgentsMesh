load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "user",
    srcs = [
        "git_credential.go",
        "hooks.go",
        "repository.go",
        "repository_provider.go",
        "user.go",
        "validation.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/domain/user",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/pkg/slugkit",
    ],
)

alias(
    name = "go_default_library",
    actual = ":user",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "user_test",
    srcs = [
        "hooks_test.go",
        "repository_provider_test.go",
        "user_test.go",
        "validation_test.go",
    ],
    embed = [":user"],
)
