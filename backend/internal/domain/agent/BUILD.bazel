load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "agent",
    srcs = [
        "agent.go",
        "config_values.go",
        "hooks.go",
        "message.go",
        "repository.go",
        "user_config.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/domain/agent",
    visibility = ["//backend:__subpackages__"],
    deps = ["//backend/pkg/slugkit"],
)

alias(
    name = "go_default_library",
    actual = ":agent",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "agent_test",
    srcs = [
        "agent_test.go",
        "config_values_test.go",
        "hooks_test.go",
        "message_test.go",
        "user_config_test.go",
    ],
    embed = [":agent"],
)
