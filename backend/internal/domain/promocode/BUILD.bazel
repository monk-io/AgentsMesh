load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "promocode",
    srcs = [
        "promocode.go",
        "repository.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/domain/promocode",
    visibility = ["//backend:__subpackages__"],
