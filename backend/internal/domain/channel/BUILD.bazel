        "binding_model.go",
        "binding_repository.go",
        "channel.go",
        "hooks.go",
        "member.go",
        "message_content.go",
        "message_content_table.go",
        "message_content_validation.go",
        "message_edit.go",
        "message_mentions.go",
        "read_state.go",
