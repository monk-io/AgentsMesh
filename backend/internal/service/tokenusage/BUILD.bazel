load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "tokenusage",
    srcs = ["service.go"],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/tokenusage",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/domain/tokenusage",
        "//proto/runner/v1:runner_go_proto",
    ],
)

alias(
    name = "go_default_library",
    actual = ":tokenusage",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "tokenusage_test",
    srcs = [
        "service_test.go",
        "tokenusage_integration_test.go",
    ],
    embed = [":tokenusage"],
    deps = [
        "//backend/internal/domain/tokenusage",
        "//backend/internal/infra",
        "//backend/internal/testkit",
        "//proto/runner/v1:runner_go_proto",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
