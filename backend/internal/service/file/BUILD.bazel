load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "file",
    srcs = [
        "mock_service.go",
        "service.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/file",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/config",
        "//backend/internal/infra/storage",
        "@com_github_google_uuid//:uuid",
    ],
)

alias(
    name = "go_default_library",
    actual = ":file",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "file_test",
    srcs = [
        "service_setup_test.go",
        "service_upload_test.go",
        "service_util_test.go",
    ],
    embed = [":file"],
    deps = [
        "//backend/internal/config",
        "//backend/internal/infra/storage",
    ],
)
