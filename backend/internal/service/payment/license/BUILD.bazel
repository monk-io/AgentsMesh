load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "license",
    srcs = [
        "provider.go",
        "provider_activation.go",
        "verify.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/payment/license",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/config",
        "//backend/internal/domain/billing",
        "//backend/internal/service/payment/types",
    ],
)

alias(
    name = "go_default_library",
    actual = ":license",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "license_test",
    srcs = [
        "license_integration_test.go",
        "provider_test.go",
    ],
    embed = [":license"],
    deps = [
        "//backend/internal/config",
        "//backend/internal/domain/billing",
        "//backend/internal/infra",
        "//backend/internal/testkit",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_gorm_gorm//:gorm",
    ],
)
