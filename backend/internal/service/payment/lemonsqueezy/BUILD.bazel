alias(
    name = "go_default_library",
    actual = ":lemonsqueezy",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "lemonsqueezy_test",
    srcs = [
        "provider_api_test.go",
        "provider_parse_test.go",
        "provider_signature_test.go",
        "provider_webhook_test.go",
    ],
    embed = [":lemonsqueezy"],
    deps = [
        "//backend/internal/config",
        "//backend/internal/domain/billing",
        "//backend/internal/service/payment/types",
    ],
