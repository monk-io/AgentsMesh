load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "lemonsqueezy",
    srcs = [
        "checkout.go",
        "provider.go",
        "subscription.go",
        "webhook.go",
        "webhook_types.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/payment/lemonsqueezy",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/config",
        "//backend/internal/domain/billing",
        "//backend/internal/service/payment/types",
        "@com_github_ndolestudio_lemonsqueezy_go//:lemonsqueezy-go",
