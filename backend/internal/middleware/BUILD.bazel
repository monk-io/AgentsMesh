load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "middleware",
    srcs = [
        "admin.go",
        "apikey.go",
        "audit.go",
        "audit_actions.go",
        "audit_query.go",
        "audit_types.go",
        "auth.go",
        "ratelimit.go",
        "tenant.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/middleware",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/domain/user",
        "//backend/internal/infra/database",
