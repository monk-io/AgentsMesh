    importpath = "github.com/anthropics/agentsmesh/backend/internal/api/connect/admin/support_ticket",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/api/connect/interceptors",
        "//backend/internal/domain/admin",
        "//backend/internal/domain/supportticket",
        "//backend/internal/domain/user",
        "//backend/internal/infra/database",
        "//backend/internal/service/admin",
        "//backend/internal/service/supportticket",
        "//backend/pkg/protoconv",
        "//proto/support_ticket/v1:support_ticket_go_proto",
        "@com_connectrpc_connect//:connect",
    ],
)

alias(
    name = "go_default_library",
    actual = ":support_ticket",
    visibility = ["//backend:__subpackages__"],
)
