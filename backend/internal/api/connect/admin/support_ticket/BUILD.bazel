    output = "support_ticket_admin_convert.amesh.go",
    proto = "//proto/support_ticket/v1:support_ticket_proto",
    proto_file = "support_ticket_admin.proto",
)

go_library(
    name = "support_ticket",
    srcs = [
        "audit.go",
        "handlers_mutations.go",
        "handlers_query.go",
        "server.go",
        "support_ticket_admin_convert_custom.go",
        ":support_ticket_admin_convert_amesh",
