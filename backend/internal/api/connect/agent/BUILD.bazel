load("@rules_go//go:def.bzl", "go_library")
load("//build_defs/protoconv:defs.bzl", "amesh_proto_convert")

amesh_proto_convert(
    name = "agent_convert_amesh",
    output = "agent_convert.amesh.go",
    proto = "//proto/agent/v1:agent_proto",
)

go_library(
    name = "agent",
    srcs = [
        "agent_convert_custom.go",
        "agent_handlers.go",
        "agent_handlers_custom.go",
        "mount.go",
        "server.go",
        "user_config_handlers.go",
        ":agent_convert_amesh",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/api/connect/agent",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//agentfile/extract",
        "//agentfile/parser",
        "//backend/internal/api/connect/interceptors",
        "//backend/internal/domain/agent",
        "//backend/internal/middleware",
        "//backend/internal/service/agent",
        "//backend/pkg/protoconv",
        "//proto/agent/v1:agent_go_proto",
        "@com_connectrpc_connect//:connect",
    ],
)

alias(
    name = "go_default_library",
    actual = ":agent",
    visibility = ["//backend:__subpackages__"],
)
