load("@rules_go//go:def.bzl", "go_library")

go_library(
    name = "agent",
    srcs = [
        "agent_handlers.go",
        "agent_handlers_custom.go",
        "convert.go",
        "mount.go",
        "server.go",
        "user_config_handlers.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/api/connect/agent",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//agentfile/extract",
        "//agentfile/parser",
        "//backend/internal/api/connect/interceptors",
        "//backend/internal/domain/agent",
        "//backend/internal/middleware",
        "//backend/internal/service/agent",
        "//proto/agent/v1:agent_go_proto",
        "@com_connectrpc_connect//:connect",
    ],
)

alias(
    name = "go_default_library",
    actual = ":agent",
    visibility = ["//backend:__subpackages__"],
)
