load("@rules_go//go:def.bzl", "go_library")
load("//build_defs/protoconv:defs.bzl", "amesh_proto_convert")

amesh_proto_convert(
    name = "user_credential_convert_amesh",
    output = "user_credential_convert.amesh.go",
    proto = "//proto/user_credential/v1:user_credential_proto",
)

go_library(
    name = "user_credential",
    srcs = [
        "git_credential.go",
        "repository_provider.go",
        "server.go",
        "user_credential_convert_custom.go",
        ":user_credential_convert_amesh",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/api/connect/user_credential",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/domain/user",
        "//backend/internal/infra/git",
        "//backend/internal/middleware",
        "//backend/internal/service/user",
        "//backend/pkg/protoconv",
        "//proto/user_credential/v1:user_credential_go_proto",
        "@com_connectrpc_connect//:connect",
    ],
)

alias(
    name = "go_default_library",
    actual = ":user_credential",
    visibility = ["//backend:__subpackages__"],
)
