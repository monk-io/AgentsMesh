load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//build_defs/protoconv:defs.bzl", "amesh_proto_convert")

amesh_proto_convert(
    name = "pod_convert_amesh",
    output = "pod_convert.amesh.go",
    proto = "//proto/pod/v1:pod_proto",
    proto_file = "pod.proto",
)

go_library(
    name = "pod",
    srcs = [
        "connection.go",
        "mount.go",
        "mutations.go",
        "pod_convert_custom.go",
        "queries.go",
        "server.go",
        ":pod_convert_amesh",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/api/connect/pod",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/api/connect/interceptors",
        "//backend/internal/domain/agent",
        "//backend/internal/domain/agentpod",
        "//backend/internal/domain/gitprovider",
        "//backend/internal/domain/grant",
        "//backend/internal/domain/runner",
        "//backend/internal/domain/ticket",
        "//backend/internal/domain/user",
        "//backend/internal/infra/eventbus",
        "//backend/internal/middleware",
        "//backend/internal/service/agentpod",
        "//backend/internal/service/billing",
        "//backend/internal/service/geo",
        "//backend/internal/service/grant",
        "//backend/internal/service/relay",
        "//backend/internal/service/runner",
        "//backend/pkg/policy",
        "//backend/pkg/protoconv",
        "//proto/events/v1:events_go_proto",
        "//proto/pod/v1:pod_go_proto",
        "@com_connectrpc_connect//:connect",
    ],
)

go_test(
    name = "pod_test",
    srcs = ["server_test.go"],
    embed = [":pod"],
    deps = [
        "//backend/internal/domain/agentpod",
        "//backend/internal/middleware",
        "//backend/internal/service/agentpod",
        "//backend/internal/service/billing",
        "//backend/internal/service/runner",
        "//proto/pod/v1:pod_go_proto",
        "@com_connectrpc_connect//:connect",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)

alias(
    name = "go_default_library",
    actual = ":pod",
    visibility = ["//backend:__subpackages__"],
)
