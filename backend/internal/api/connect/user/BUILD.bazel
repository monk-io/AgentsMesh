load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "user",
    srcs = [
        "convert.go",
        "identities.go",
        "profile.go",
        "search.go",
        "server.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/api/connect/user",
    visibility = ["//backend:__subpackages__"],
    deps = [
