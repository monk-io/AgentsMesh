load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "dns",
    srcs = [
        "aliyun_a_record.go",
        "aliyun_request.go",
        "aliyun_txt_record.go",
        "cloudflare.go",
        "cloudflare_txt.go",
        "cloudflare_types.go",
        "provider.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/infra/dns",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/config",
        "@com_github_google_uuid//:uuid",
        "@io_opentelemetry_go_contrib_instrumentation_net_http_otelhttp//:otelhttp",
    ],
)

alias(
    name = "go_default_library",
    actual = ":dns",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "dns_test",
    srcs = ["provider_integration_test.go"],
    embed = [":dns"],
    deps = [
        "//backend/internal/config",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
