load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "websocket",
    srcs = [
        "client.go",
        "hub.go",
        "hub_broadcast.go",
        "hub_event_subscriber.go",
        "hub_query.go",
        "hub_registration.go",
        "hub_shard.go",
        "notification_relay.go",
        "types.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/infra/websocket",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/infra/eventbus",
        "@com_github_google_uuid//:uuid",
        "@com_github_gorilla_websocket//:websocket",
        "@com_github_redis_go_redis_v9//:go-redis",
    ],
)

alias(
    name = "go_default_library",
    actual = ":websocket",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "websocket_test",
    srcs = [
        "hub_advanced_test.go",
        "hub_basic_test.go",
        "hub_broadcast_org_test.go",
        "hub_broadcast_pod_test.go",
        "hub_event_subscriber_test.go",
        "notification_relay_test.go",
    ],
    embed = [":websocket"],
    deps = [
        "//backend/internal/infra/eventbus",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
