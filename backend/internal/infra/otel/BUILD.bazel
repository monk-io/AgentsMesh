load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "otel",
    srcs = [
        "metrics.go",
        "provider.go",
        "trace_context_handler.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/infra/otel",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "@io_opentelemetry_go_otel//:otel",
        "@io_opentelemetry_go_otel//propagation",
        "@io_opentelemetry_go_otel//semconv/v1.26.0:v1_26_0",
        "@io_opentelemetry_go_otel_exporters_otlp_otlpmetric_otlpmetricgrpc//:otlpmetricgrpc",
        "@io_opentelemetry_go_otel_exporters_otlp_otlptrace_otlptracegrpc//:otlptracegrpc",
        "@io_opentelemetry_go_otel_metric//:metric",
        "@io_opentelemetry_go_otel_metric//noop",
        "@io_opentelemetry_go_otel_sdk//resource",
        "@io_opentelemetry_go_otel_sdk//trace",
        "@io_opentelemetry_go_otel_sdk_metric//:metric",
        "@io_opentelemetry_go_otel_trace//:trace",
    ],
)

alias(
    name = "go_default_library",
    actual = ":otel",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "otel_test",
    srcs = [
        "provider_test.go",
        "trace_context_handler_test.go",
    ],
    embed = [":otel"],
    deps = ["@io_opentelemetry_go_otel_sdk//trace"],
)
