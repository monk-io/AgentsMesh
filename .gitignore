# =========================
# General
# =========================
.DS_Store
._*

# Playwright e2e auth state — contains live JWTs, never commit
.auth/
*.log
*.tmp
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Environment
.env
.env.*
!.env.example

# Dependencies — catch-all for any node_modules anywhere in the tree
**/node_modules/

# =========================
# Bazel
# =========================
bazel-*
.bazel-cache/
.bazelrc.local

# =========================
# Frontend (Next.js / Web)
# =========================
clients/web/node_modules/
clients/web/.next/
clients/web/out/
clients/web/build/
clients/web/.pnp
clients/web/.pnp.*
clients/web/.yarn/*
!clients/web/.yarn/patches
!clients/web/.yarn/plugins
!clients/web/.yarn/releases
!clients/web/.yarn/versions
clients/web/coverage/
clients/web/*.pem
clients/web/npm-debug.log*
clients/web/yarn-debug.log*
clients/web/yarn-error.log*
clients/web/.pnpm-debug.log*
clients/web/.vercel
clients/web/*.tsbuildinfo
clients/web/next-env.d.ts

# Playwright run artifacts — regenerated every run, never commit.
clients/web/test-results/
clients/web/playwright-report/
clients/web/e2e-playwright/node_modules/
clients/web/e2e-playwright/test-results/
clients/web/e2e-playwright/playwright-report/

# Web-Admin (Next.js)
clients/web-admin/node_modules/
clients/web-admin/.next/
clients/web-admin/out/
clients/web-admin/build/
clients/web-admin/coverage/
clients/web-admin/next-env.d.ts
clients/web-admin/*.tsbuildinfo

# Desktop (Electron)
clients/desktop/node_modules/
clients/desktop/out/
clients/desktop/dist/
clients/desktop/test-results/
clients/desktop/playwright-report/

# Playwright sometimes drops artifacts at the repo root when invoked
# from a non-package CWD (e.g. a Bazel runfiles tree). Cover that too.
/test-results/
/playwright-report/

# =========================
# Backend (Go)
# =========================
backend/bin/
backend/tmp/
backend/vendor/
backend/server
backend/coverage.html

# Phase 12 codegen — *_convert.amesh.go is generated by
# //tools/protoc-gen-amesh-convert via the amesh_proto_convert Bazel
# macro (build_defs/protoconv/defs.bzl). Output lives in bazel-bin/;
# never commit a source-tree copy. See ADR
# .claude/adr/2026-05-25-convert-codegen.md.
backend/internal/api/connect/**/*_convert.amesh.go

# =========================
# Runner (Go)
# =========================
runner/bin/
runner/tmp/
runner/*.out
runner/runner
runner/runner.exe
runner/coverage.html

# =========================
# Relay (Go)
# =========================
relay/bin/
relay/tmp/
relay/*.out
relay/relay
relay/coverage.html

# =========================
# Docker
# =========================
.docker/

# =========================
# Dev environment (auto-generated by dev.sh)
# =========================
deploy/dev/traefik/traefik.yml
deploy/dev/traefik/dynamic/http.yml
deploy/dev/traefik/dynamic/grpc.yml
# Host-side service runtime state (PIDs, logs, isolated HOME, runner certs)
deploy/dev/runtime/
# Bazel-built runner binary copied into the runner docker build context
deploy/dev/runner-binary
# Bazel-built e2e-mock-agent binary (same copy-into-build-context pattern)
deploy/dev/e2e-mock-agent-binary

# SSH keys for dev runner (auto-generated by dev.sh)
deploy/dev/runner-ssh/id_*
deploy/dev/runner-ssh/known_hosts

# =========================
# Creative assets (demo videos, screenshots, etc.)
# =========================
creative/

# =========================
# Test artifacts
# =========================
*.out
*.test
*_coverage.out
coverage.out
runner/dist/
images/backend.tar
images/minio.tar
images/postgres.tar
images/redis.tar
images/relay.tar
images/traefik.tar
images/web-admin.tar
images/web.tar
runner/agentsmesh-runner
agentsmesh-onpremise-v1.0.0.tar.gz

# =========================
# Rust / WASM (clients/core/)
# =========================
clients/core/target/
clients/core/**/target/
# Defensive ignore: catch stray wasm-pack outputs if anyone runs the
# legacy CLI by accident. The canonical pipeline is Bazel-native via
# //clients/core/crates/wasm:wasm_pkg → :wasm_pkg_npm.
clients/core/crates/*/pkg/
clients/core/crates/*/*/pkg/
clients/core/crates/*/*/*/pkg/
clients/core/core/pkg/
clients/core/pkg/

# napi `.node` addons — built by Bazel via napi_rust_library, never
# committed. The tree-relative names exist briefly in dev workflows
# (e.g. when running napi-cli outside Bazel for debugging) but the
# canonical build path is `bazel build //clients/core/crates/node-bridge`.
clients/core/crates/node-bridge/*.node

# iOS build outputs — the XCFramework is produced by
# //clients/core/crates/ffi:AgentsMeshCore (pure Bazel). Local dev
# wires bazel-bin/ outputs into the SPM tree via `clients/ios/Makefile
# link-core`, which drops symlinks into the two ignored paths below.
clients/ios/Packages/AgentsMeshCore/Sources/AgentsMeshCoreFFI/AgentsMeshCore.xcframework
clients/ios/Packages/AgentsMeshCore/Sources/AgentsMeshCore/Generated/

# =========================
# iOS (Swift / Xcode)
# =========================
clients/ios/DerivedData/
clients/ios/**/xcuserdata/
clients/ios/**/*.xcuserstate
clients/ios/build/
clients/ios/.swiftpm/
clients/ios/**/.build/
# XcodeGen-generated project (regenerated from project.yml)
clients/ios/AgentsMesh.xcodeproj/
# Symlinks created by `make link-core`
clients/ios/Packages/AgentsMeshCore/Sources/AgentsMeshCore/Generated/AgentsMeshCore.swift
clients/ios/Packages/AgentsMeshCore/Sources/AgentsMeshCoreFFI/AgentsMeshCore.xcframework

# =========================
# Claude Code
# =========================
.claude/worktrees/
.claude/*.png
.claude/cred-dialog-*

# =========================
# Reports (generated artifacts)
# =========================
E2E_TEST_REPORT.md
.loopal/worktrees/
third_party/swift/.build/

# Bazel symlinks (created by build, never tracked)
/node_modules
/clients/desktop/out
