# =========================
# Rust / WASM (clients/core/)
# =========================
clients/core/target/
clients/core/**/target/
# wasm-pack intermediate outputs (stale builds in wrong locations)
clients/core/crates/*/pkg/
clients/core/crates/*/*/pkg/
clients/core/crates/*/*/*/pkg/
clients/core/core/pkg/
# Keep clients/core/pkg/ — it's the canonical wasm-pack output referenced by clients/web/package.json

# iOS build outputs (regenerated by build-ios-xcframework.sh)
clients/core/ios-framework/AgentsMeshCore.xcframework/
clients/core/ios-framework/Generated/
clients/core/ios-framework/Headers/
clients/core/ios-framework/sim/
clients/core/ios-framework/*.zip

# =========================
# iOS (Swift / Xcode)
# =========================
clients/ios/DerivedData/
clients/ios/**/xcuserdata/
clients/ios/**/*.xcuserstate
clients/ios/build/
clients/ios/.swiftpm/
clients/ios/**/.build/
# XcodeGen-generated project (regenerated from project.yml)
clients/ios/AgentsMesh.xcodeproj/
# Symlinks created by `make link-core`
clients/ios/Packages/AgentsMeshCore/Sources/AgentsMeshCore/Generated/AgentsMeshCore.swift
clients/ios/Packages/AgentsMeshCore/Sources/AgentsMeshCoreFFI/AgentsMeshCore.xcframework

