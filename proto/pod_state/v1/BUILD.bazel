load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library", "rust_prost_transform")

# Client-state mutation contract for the pod domain. Distinct from
# proto.pod.v1 (wire schema for Connect-RPC) — this package carries the
# SRP-shaped mutation messages issued by TS/Swift renderer code against
# the Rust pod cache via wasm-bindgen / NAPI / UniFFI.
#
# See pod_state.proto for the full design rationale and message catalog.

rust_prost_transform(
    name = "pod_state_serde_transform",
    prost_opts = [
        "type_attribute=.=#[derive(serde::Serialize\\, serde::Deserialize)]",
        "type_attribute=.=#[serde(default)]",
    ],
    deps = ["@crates//:serde"],
)

proto_library(
    name = "pod_state_proto",
    srcs = ["pod_state.proto"],
    data = [":pod_state_serde_transform"],
    visibility = ["//visibility:public"],
    deps = ["//proto/pod/v1:pod_proto"],
)

go_proto_library(
    name = "pod_state_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/pod_state/v1",
    proto = ":pod_state_proto",
    visibility = ["//visibility:public"],
    deps = ["//proto/pod/v1:pod_go_proto"],
)

rust_prost_library(
    name = "pod_state_rust_proto",
    proto = ":pod_state_proto",
    visibility = ["//visibility:public"],
)
