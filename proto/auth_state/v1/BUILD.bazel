load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library", "rust_prost_transform")

# Desktop NAPI auth state mutation contract. See auth_state.proto for
# the business intent — auth/org persistence in the Electron main
# process flows through these messages.

rust_prost_transform(
    name = "auth_state_serde_transform",
    prost_opts = [
        "type_attribute=.=#[derive(serde::Serialize\\, serde::Deserialize)]",
        "type_attribute=.=#[serde(default)]",
    ],
    deps = ["@crates//:serde"],
)

proto_library(
    name = "auth_state_proto",
    srcs = ["auth_state.proto"],
    data = [":auth_state_serde_transform"],
    visibility = ["//visibility:public"],
    deps = [
        "//proto/auth/v1:auth_proto",
        "//proto/org/v1:org_proto",
    ],
)

go_proto_library(
    name = "auth_state_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/auth_state/v1",
    proto = ":auth_state_proto",
    visibility = ["//visibility:public"],
    deps = [
        "//proto/auth/v1:auth_go_proto",
        "//proto/org/v1:org_go_proto",
    ],
)

rust_prost_library(
    name = "auth_state_rust_proto",
    proto = ":auth_state_proto",
    visibility = ["//visibility:public"],
)
