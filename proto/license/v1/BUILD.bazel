load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

# Bazel-native protobuf code generation for license.v1.
#
# Mirrors proto/binding/v1/BUILD.bazel — same hermetic protoc/protoc-gen-go
# pipeline, same `proto/gen/go/<svc>/v1` importpath shape. Rust prost DTOs
# are hand-maintained at clients/core/crates/types/src/license_proto.rs;
# `tools/validate_prost_tags` pins .proto field number ↔ Rust
# `prost(tag = N)` mapping at build time (watch list hazard #8).
#
# TS message classes for the binary wire (conventions §2.5) ship as a
# committed mirror under proto/gen/ts/license/v1/ — produced by
# `pnpm proto:gen-ts`.

proto_library(
    name = "license_proto",
    srcs = ["license.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "license_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/license/v1",
    proto = ":license_proto",
    visibility = ["//visibility:public"],
)

# Watch list hazard #8 — catch hand-written prost struct drift.
validate_prost_tags(
    name = "license_validate",
    proto = "license.proto",
    rust = "//clients/core/crates/types:src/license_proto.rs",
)
