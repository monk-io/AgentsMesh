load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

# Bazel-native protobuf code generation for admin.v1.
#
# Mirrors proto/binding/v1/BUILD.bazel — same hermetic protoc/protoc-gen-go
# pipeline, same `proto/gen/go/<svc>/v1` importpath shape.
#
# No `validate_prost_tags` here: the AdminService surface has no Rust
# client today (web-admin runs as a plain Next.js app without wasm-core).
# Add the Rust DTO + validator when an admin Rust binding lands.

proto_library(
    name = "admin_proto",
    srcs = ["admin.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "admin_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/admin/v1",
    proto = ":admin_proto",
    visibility = ["//visibility:public"],
)
