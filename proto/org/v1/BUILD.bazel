load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

# Bazel-native protobuf code generation for org.v1.
#
# Same hermetic protoc/protoc-gen-go pipeline as proto/extension/v1. The Rust
# prost DTOs are hand-maintained at clients/core/crates/types/src/org_proto.rs
# (Rust source-of-truth pending `tools/gen_rust_proto` codegen);
# `tools/validate_prost_tags` pins the .proto field number ↔ Rust
# `prost(tag = N)` mapping at build time (watch list #8).
#
# TS message classes for the binary wire (conventions §2.5) ship as a
# committed mirror under proto/gen/ts/org/v1/ — pending Bazel-native
# `ts_proto_library` macro per runbook "TS proto codegen toolchain".

proto_library(
    name = "org_proto",
    srcs = ["org.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "org_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/org/v1",
    proto = ":org_proto",
    visibility = ["//visibility:public"],
)

# Watch list hazard #8 — catch hand-written prost struct drift.
validate_prost_tags(
    name = "org_validate",
    proto = "org.proto",
    rust = "//clients/core/crates/types:src/org_proto.rs",
)
