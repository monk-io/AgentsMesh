load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library", "rust_prost_transform")

# Client-state schema for the channel domain. Distinct from
# proto.channel.v1 (wire schema for Connect-RPC) — this package describes
# the Rust-side cache shape (wire fields + Rust-derived business fields
# like unread_count / last_message preview). See channel_state.proto for
# the full design rationale.

rust_prost_transform(
    name = "channel_state_serde_transform",
    prost_opts = [
        "type_attribute=.=#[derive(serde::Serialize\\, serde::Deserialize)]",
        "type_attribute=.=#[serde(default)]",
    ],
    deps = ["@crates//:serde"],
)

proto_library(
    name = "channel_state_proto",
    srcs = ["channel_state.proto"],
    data = [":channel_state_serde_transform"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "channel_state_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/channel_state/v1",
    proto = ":channel_state_proto",
    visibility = ["//visibility:public"],
)

rust_prost_library(
    name = "channel_state_rust_proto",
    proto = ":channel_state_proto",
    visibility = ["//visibility:public"],
)
