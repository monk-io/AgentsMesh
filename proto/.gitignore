# Generated .pb.go stubs. Built by `bazel build //proto/<svc>/v1:<svc>_go_proto`
# (synced into this tree by build_defs/go/golangci_lint_runner.sh before lint
# runs, so golangci-lint's typecheck pass can resolve the proto module).
gen/go/

# TS message classes: committed mirror, generated by `node_modules/.bin/buf generate`.
# Re-generate after editing any .proto file. Committed (not gitignored) because
# vitest, ESLint, and Next.js production builds all need to consume them
# without a Bazel codegen toolchain at hand. Replaced by `ts_proto_library`
# Bazel macro in a follow-up PR (runbook §"TS proto codegen toolchain").
