load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library", "rust_prost_transform")

rust_prost_transform(
    name = "repo_state_serde_transform",
    prost_opts = [
        "type_attribute=.=#[derive(serde::Serialize\\, serde::Deserialize)]",
        "type_attribute=.=#[serde(default)]",
    ],
    deps = ["@crates//:serde"],
)

proto_library(
    name = "repo_state_proto",
    srcs = ["repo_state.proto"],
    data = [":repo_state_serde_transform"],
    strip_import_prefix = "/proto",
    visibility = ["//visibility:public"],
    deps = ["//proto/repository/v1:repository_proto"],
)

go_proto_library(
    name = "repo_state_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/repo_state/v1",
    proto = ":repo_state_proto",
    visibility = ["//visibility:public"],
    deps = ["//proto/repository/v1:repository_go_proto"],
)

rust_prost_library(
    name = "repo_state_rust_proto",
    proto = ":repo_state_proto",
    visibility = ["//visibility:public"],
)
