load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

# Bazel-native protobuf code generation for runner_api.v1.
#
# Mirrors proto/extension/v1/BUILD.bazel — same hermetic protoc/protoc-gen-go
# pipeline, same `proto/gen/go/<svc>/v1` importpath shape.
#
# Package note: this is `proto.runner_api.v1`, NOT `proto.runner.v1`. The
# latter is already taken by the runner ↔ backend gRPC mTLS control plane
# (proto/runner/v1/runner.proto). This service is the browser/desktop ↔
# backend user-facing REST replacement — completely different plane.
#
# The Rust prost DTOs are hand-maintained at
# clients/core/crates/types/src/runner_proto.rs (Rust source-of-truth
# pending `tools/gen_rust_proto` codegen — see ADR §"Codegen");
# `tools/validate_prost_tags` pins the .proto field number ↔ Rust
# `prost(tag = N)` mapping at build time.
#
# TS message classes for the binary wire ship as a committed mirror under
# proto/gen/ts/runner_api/v1/ — pending Bazel-native `ts_proto_library`
# macro per runbook "TS proto codegen toolchain".

proto_library(
    name = "runner_api_proto",
    srcs = ["runner.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "runner_api_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/runner_api/v1",
    proto = ":runner_api_proto",
    visibility = ["//visibility:public"],
)

# Watch list hazard #8 — catch hand-written prost struct drift.
validate_prost_tags(
    name = "runner_api_validate",
    proto = "runner.proto",
    rust = "//clients/core/crates/types:src/runner_proto.rs",
)
