load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

# Bazel-native protobuf code generation for repository.v1.
#
# Mirrors proto/extension/v1/BUILD.bazel — same hermetic protoc/protoc-gen-go
# pipeline, same `proto/gen/go/<svc>/v1` importpath shape. The Rust prost
# DTOs are hand-maintained at clients/core/crates/types/src/repository_proto.rs
# (Rust source-of-truth pending `tools/gen_rust_proto` codegen — see
# ADR §"Codegen"); `tools/validate_prost_tags` (//proto/repository/v1:repository_validate)
# pins the .proto field number ↔ Rust `prost(tag = N)` mapping at build time.
#
# TS message classes for the binary wire (conventions §2.5) ship as a
# committed mirror under proto/gen/ts/repository/v1/ — pending Bazel-native
# `ts_proto_library` macro per runbook "TS proto codegen toolchain".

# Watch list hazard #8 — catch hand-written prost struct drift.
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

proto_library(
    name = "repository_proto",
    srcs = ["repository.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "repository_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/repository/v1",
    proto = ":repository_proto",
    visibility = ["//visibility:public"],
)

validate_prost_tags(
    name = "repository_validate",
    proto = "repository.proto",
    rust = "//clients/core/crates/types:src/repository_proto.rs",
)
