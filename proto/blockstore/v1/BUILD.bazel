load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

# Bazel-native protobuf code generation for blockstore.v1.
#
# Mirrors proto/channel/v1/BUILD.bazel — same hermetic protoc/protoc-gen-go
# pipeline, same `proto/gen/go/<svc>/v1` importpath shape. The Rust prost
# DTOs are hand-maintained at clients/core/crates/types/src/blockstore_proto.rs;
# `tools/validate_prost_tags` pins .proto field number ↔ Rust
# `prost(tag = N)` mapping at build time (watch list hazard #8).

proto_library(
    name = "blockstore_proto",
    srcs = ["blockstore.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "blockstore_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/blockstore/v1",
    proto = ":blockstore_proto",
    visibility = ["//visibility:public"],
)

# Watch list hazard #8 — catch hand-written prost struct drift.
validate_prost_tags(
    name = "blockstore_validate",
    proto = "blockstore.proto",
    rust = "//clients/core/crates/types:src/blockstore_proto.rs",
)
