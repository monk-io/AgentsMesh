load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

# Bazel-native protobuf code generation for apikey.v1.
#
# Mirrors proto/extension/v1/BUILD.bazel (the migration reference) —
# same hermetic protoc/protoc-gen-go pipeline, same `proto/gen/go/<svc>/v1`
# importpath shape. The Rust prost DTOs are hand-maintained at
# clients/core/crates/types/src/apikey_proto.rs;
# `tools/validate_prost_tags` pins .proto field number ↔ Rust
# `prost(tag = N)` mapping at build time (watch list hazard #8).
#
# TS message classes for the binary wire (conventions §2.5) ship as a
# committed mirror under proto/gen/ts/apikey/v1/ — produced by
# `pnpm proto:gen-ts`.

proto_library(
    name = "apikey_proto",
    srcs = ["api_key.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "apikey_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/apikey/v1",
    proto = ":apikey_proto",
    visibility = ["//visibility:public"],
)

# Watch list hazard #8 — catch hand-written prost struct drift.
validate_prost_tags(
    name = "apikey_validate",
    proto = "api_key.proto",
    rust = "//clients/core/crates/types:src/apikey_proto.rs",
)
