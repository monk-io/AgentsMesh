load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library")

proto_library(
    name = "promocode_proto",
    # Admin surface lives next door in promocode_admin.proto. Same go_package
    # option so both compile into one generated Go pkg; Bazel groups them into
    # the same go_proto_library by virtue of the shared srcs entry.
    srcs = [
        "promocode.proto",
        "promocode_admin.proto",
    ],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "promocode_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/promocode/v1",
    proto = ":promocode_proto",
    visibility = ["//visibility:public"],
)

rust_prost_library(
    name = "promocode_rust_proto",
    proto = ":promocode_proto",
    visibility = ["//visibility:public"],
)
