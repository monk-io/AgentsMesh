load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

# Bazel-native protobuf code generation for binding.v1.
#
# Mirrors proto/extension/v1/BUILD.bazel (the migration reference) —
# same hermetic protoc/protoc-gen-go pipeline, same `proto/gen/go/<svc>/v1`
# importpath shape. The Rust prost DTOs are hand-maintained at
# clients/core/crates/types/src/binding_proto.rs;
# `tools/validate_prost_tags` pins .proto field number ↔ Rust
# `prost(tag = N)` mapping at build time (watch list hazard #8).
#
# TS message classes for the binary wire (conventions §2.5) ship as a
# committed mirror under proto/gen/ts/binding/v1/ — produced by
# `pnpm proto:gen-ts`.

proto_library(
    name = "binding_proto",
    srcs = ["binding.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "binding_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/binding/v1",
    proto = ":binding_proto",
    visibility = ["//visibility:public"],
)

# Watch list hazard #8 — catch hand-written prost struct drift.
validate_prost_tags(
    name = "binding_validate",
    proto = "binding.proto",
    rust = "//clients/core/crates/types:src/binding_proto.rs",
)
