load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library")

# Bazel-native protobuf code generation for billing.v1.
#
# Two services in this file (BillingService + BillingPublicService) share
# the same generated Go module. Rust types are auto-generated by
# `rust_prost_library` and re-exported by `clients/core/crates/types/`
# under `proto_billing_v1` — no more hand-written prost mirror.
#
# TS message classes ship as a committed mirror under proto/gen/ts/billing/v1/
# — pending Bazel-native `ts_proto_library` macro per runbook.

proto_library(
    name = "billing_proto",
    # Admin surface lives next door in billing_admin.proto. Same go_package
    # option so both compile into one generated Go pkg; Bazel groups them into
    # the same go_proto_library by virtue of the shared srcs entry.
    srcs = [
        "billing.proto",
        "billing_admin.proto",
    ],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "billing_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/billing/v1",
    proto = ":billing_proto",
    visibility = ["//visibility:public"],
)

rust_prost_library(
    name = "billing_rust_proto",
    proto = ":billing_proto",
    visibility = ["//visibility:public"],
)
