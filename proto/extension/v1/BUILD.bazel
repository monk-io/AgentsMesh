load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("//tools/validate_prost_tags:rule.bzl", "validate_prost_tags")

# Bazel-native protobuf code generation for extension.v1.
#
# Mirrors proto/runner/v1/BUILD.bazel — same hermetic protoc/protoc-gen-go
# pipeline, same `proto/gen/go/<svc>/v1` importpath shape. The Rust prost
# DTOs are hand-maintained at clients/core/crates/types/src/extension_proto.rs
# (Rust source-of-truth pending `tools/gen_rust_proto` codegen — see
# ADR §"Codegen"); `tools/validate_prost_tags` pins the
# .proto field number ↔ Rust `prost(tag = N)` mapping at build time.
#
# TS message classes for the binary wire (conventions §2.5) ship as a
# committed mirror under proto/gen/ts/extension/v1/ — pending Bazel-native
# `ts_proto_library` macro per runbook "TS proto codegen toolchain".

proto_library(
    name = "extension_proto",
    srcs = [
        "market.proto",
        "repo_mcp.proto",
        "repo_skill.proto",
        "skill_registry.proto",
        "skill_registry_admin.proto",
    ],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "extension_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/extension/v1",
    proto = ":extension_proto",
    visibility = ["//visibility:public"],
)

# Watch list hazard #8 — catch hand-written prost struct drift. One target
# per .proto / Rust file pair so a drift surfaces with the exact pair that
# diverged.
validate_prost_tags(
    name = "extension_validate",
    proto = "skill_registry.proto",
    rust = "//clients/core/crates/types:src/extension_proto.rs",
)

validate_prost_tags(
    name = "extension_market_validate",
    proto = "market.proto",
    rust = "//clients/core/crates/types:src/extension_market_proto.rs",
)

validate_prost_tags(
    name = "extension_repo_skill_validate",
    proto = "repo_skill.proto",
    rust = "//clients/core/crates/types:src/extension_repo_skill_proto.rs",
)

validate_prost_tags(
    name = "extension_repo_mcp_validate",
    proto = "repo_mcp.proto",
    rust = "//clients/core/crates/types:src/extension_repo_mcp_proto.rs",
)
