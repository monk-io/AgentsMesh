load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

# Bazel-native protobuf code generation for extension.v1.
#
# Mirrors proto/runner/v1/BUILD.bazel — same hermetic protoc/protoc-gen-go
# pipeline, same `proto/gen/go/<svc>/v1` importpath shape. The Rust prost
# DTOs are hand-maintained at clients/core/crates/types/src/extension.rs
# (Rust source-of-truth pending `tools/gen_rust_proto` codegen — see
# ADR §"Codegen"); `tools/validate_prost_tags` pins the
# .proto field number ↔ Rust `prost(tag = N)` mapping at build time.
#
# TS message classes for the binary wire (conventions §2.5) ship as a
# committed mirror under proto/gen/ts/extension/v1/ — pending Bazel-native
# `ts_proto_library` macro per runbook "TS proto codegen toolchain".

proto_library(
    name = "extension_proto",
    srcs = ["skill_registry.proto"],
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "extension_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/extension/v1",
    proto = ":extension_proto",
    visibility = ["//visibility:public"],
)
