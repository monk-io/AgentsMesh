load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library", "rust_prost_transform")

# R2: opt into serde derive on every generated message/enum so the same
# Rust struct doubles as wire DTO + JSON-friendly cache/state type.
# `=.=` matches all types; `\\,` escapes the comma so protoc-gen-prost
# doesn't treat it as a flag separator.
rust_prost_transform(
    name = "auth_serde_transform",
    prost_opts = [
        "type_attribute=.=#[derive(serde::Serialize\\, serde::Deserialize)]",
        "type_attribute=.=#[serde(default)]",
    ],
    deps = ["@crates//:serde"],
)

proto_library(
    name = "auth_proto",
    srcs = ["auth.proto"],
    data = [":auth_serde_transform"],
    # Strip the `proto/` workspace prefix so downstream `proto_library`
    # targets can `import "auth/v1/auth.proto"` (the form buf v2's
    # module-root `path: proto` config emits). Required for cross-package
    # imports from proto/auth_state/v1/.
    strip_import_prefix = "/proto",
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "auth_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/auth/v1",
    proto = ":auth_proto",
    visibility = ["//visibility:public"],
)

rust_prost_library(
    name = "auth_rust_proto",
    proto = ":auth_proto",
    visibility = ["//visibility:public"],
)
