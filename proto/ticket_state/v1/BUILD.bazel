load("@rules_go//proto:def.bzl", "go_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library", "rust_prost_transform")

rust_prost_transform(
    name = "ticket_state_serde_transform",
    prost_opts = [
        "type_attribute=.=#[derive(serde::Serialize\\, serde::Deserialize)]",
        "type_attribute=.=#[serde(default)]",
    ],
    deps = ["@crates//:serde"],
)

proto_library(
    name = "ticket_state_proto",
    srcs = ["ticket_state.proto"],
    data = [":ticket_state_serde_transform"],
    visibility = ["//visibility:public"],
    deps = ["//proto/ticket/v1:ticket_proto"],
)

go_proto_library(
    name = "ticket_state_go_proto",
    compilers = ["@rules_go//proto:go_proto"],
    importpath = "github.com/anthropics/agentsmesh/proto/gen/go/ticket_state/v1",
    proto = ":ticket_state_proto",
    visibility = ["//visibility:public"],
    deps = ["//proto/ticket/v1:ticket_go_proto"],
)

rust_prost_library(
    name = "ticket_state_rust_proto",
    proto = ":ticket_state_proto",
    visibility = ["//visibility:public"],
)
