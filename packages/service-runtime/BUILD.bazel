load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//build_defs/web:ts.bzl", "ts_project")

npm_link_all_packages(name = "node_modules")

# Service-runtime — browser-side implementation of the service-interface
# types. Wraps the Rust WASM package so web and desktop renderer code
# share a single façade.
ts_project(
    name = "service_runtime",
    srcs = glob(
        ["src/**/*.ts"],
        exclude = ["src/**/*.test.ts"],
    ),
    declaration = True,
    tsconfig = "tsconfig.json",
    visibility = ["//visibility:public"],
    deps = [
        ":node_modules",
        # Bazel-built wasm is a Phase 3a TODO — reference the checked-in
        # wasm-pack output directly via its npm_package target so TS
        # compilation doesn't block on the rust_wasm_bindgen rule.
        "//clients/core/pkg",
        "//packages/service-interface:service_interface",
    ],
)

# npm_package creates the `:pkg` target that pnpm workspace link
# (`@agentsmesh/service-runtime: workspace:*`) resolves to from
# downstream packages (clients/web, clients/desktop).
#
# The npm_package ships the raw .ts sources (not the ts_project
# outputs) because package.json's `main`/`exports` both point at
# `src/index.ts`: Next.js's webpack/SWC pipeline compiles the TS
# itself, so shipping .js would orphan the .ts entry point. The
# :service_runtime ts_project still runs upstream as a type-check
# gate; it just isn't what downstream consumers link against.
npm_package(
    name = "pkg",
    srcs = ["package.json"] + glob(
        ["src/**/*.ts"],
        exclude = ["src/**/*.test.ts"],
    ),
    visibility = ["//visibility:public"],
)
