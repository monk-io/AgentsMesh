// Blocks — structured knowledge graph + indicators.
// Master-detail: sidebar (search + pages tree + indicator types + triggers footer)
//                + main (document editor with mixed block types).
// Aligned with code reality: no workspace chip (single workspace per org),
// no realtime collaborator presence (not implemented yet).
// Shows: paragraph, heading, task, view (table), summary (KPI cards),
// mention(pod), embed(ticket) — all rendered today.

canvas "blocks" {
    width      = 2000
    height     = 1160
    background = #1F2328
}

component blk_nav_icon_active(icon) {
    frame { width = 36, height = 36, radius = 6, fill = #DDF4FF, stroke = [1, #0969DA]
        layout = horizontal, justify = center, align = center
        text icon { size = 16, weight = medium, color = #0969DA }
    }
}
component blk_nav_icon(icon) {
    frame { width = 36, height = 36, radius = 6, fill = transparent
        layout = horizontal, justify = center, align = center
        text icon { size = 16, color = #656D76 }
    }
}
component blk_section_divider() { shape { type = rectangle, width = 24, height = 1, fill = #D0D7DE } }

// --- Sidebar page tree row ---
// `depth` is a left indent in px. Root page (workspace.root_block_id) renders
// at depth=0; nested pages recurse with depth+12 per level.
component page_node(icon, label, depth, is_active) {
    frame {
        width   = fill
        padding = [5, 12]
        layout  = horizontal, align = center, gap = 6
        fill    = is_active

        frame spacer { width = depth, height = 1 }
        text "›" { size = 10, color = #868F99 }
        text icon  { size = 12, color = #656D76 }
        text label { size = 13, color = #1F2328 }
    }
}

// --- Indicator type row — color dot + mono slug + count of instances ---
component type_row(color_dot, slug, count) {
    frame row {
        width = fill, layout = horizontal, gap = 8, align = center, padding = [3, 0]
        frame dot { width = 8, height = 8, radius = 2, fill = color_dot }
        text slug { size = 12, weight = medium, color = #1F2328, family = "JetBrains Mono" }
        frame spacer { width = fill }
        text count { size = 10, color = #868F99, family = "JetBrains Mono" }
    }
}

// --- KPI summary card (summary block) ---
component kpi_card(label, value, delta, delta_color, bg) {
    frame {
        width = fill, padding = 16, radius = 10
        fill  = bg, stroke = [1, #D0D7DE]
        layout = vertical, gap = 6

        text label { size = 11, weight = medium, color = #656D76, text-transform = uppercase, letter-spacing = 1 }
        frame row {
            layout = horizontal, gap = 8, align = center
            text value { size = 24, weight = semibold, color = #1F2328 }
            text delta { size = 12, weight = medium, color = delta_color }
        }
    }
}

// --- Task row (task block, inline rendered) ---
component task_row(checked, title, status_badge_text, status_bg, status_fg, owner_letter, owner_bg) {
    frame {
        width = fill, padding = [6, 10], radius = 6
        layout = horizontal, gap = 12, align = center

        frame checkbox {
            width = 16, height = 16, radius = 4, fill = checked
            layout = horizontal, justify = center, align = center
            stroke = [1, #D0D7DE]
            text "✓" { size = 10, weight = semibold, color = #FFFFFF }
        }
        frame title_wrap { width = fill
            text title { size = 13, color = #1F2328, wrap = true, width = 1000 }
        }
        frame badge { padding = [1, 8], radius = 999, fill = status_bg
            text status_badge_text { size = 10, weight = medium, color = status_fg }
        }
        frame avatar { width = 22, height = 22, radius = 999, fill = owner_bg
            layout = horizontal, justify = center, align = center
            text owner_letter { size = 10, weight = semibold, color = #FFFFFF }
        }
    }
}

// --- Table row (view block render) ---
component table_cell(text_val, w) {
    frame { width = w, padding = [8, 10]
        text text_val { size = 12, color = #1F2328, family = "JetBrains Mono" }
    }
}

component pg_blocks_document() {
frame root {
        width = 1920, height = 1080
        fill   = #FFFFFF
        radius = 12
        stroke = [2, #6E7681]
        shadow = [0, 8, 24, #00000080]
        layout = vertical

        frame body {
            width = fill, height = fill, layout = horizontal

            // === ActivityBar ===
            frame activity_bar {
                width = 48, height = fill, fill = #FFFFFF, stroke = [1, #D0D7DE]
                layout = vertical, align = center, padding = [12, 6], gap = 6

                frame org_switcher {
                    width = 36, height = 36, radius = 8, fill = #0969DA
                    layout = horizontal, justify = center, align = center
                    text "D" { size = 16, weight = semibold, color = #FFFFFF }
                }
                frame gap_s { height = 12 }

                use blk_nav_icon_active("▦")
                use blk_nav_icon("#")
                use blk_nav_icon(">_")
                use blk_section_divider()
                use blk_nav_icon("🎫")
                use blk_nav_icon("↻")
                use blk_nav_icon("⚘")

                frame spacer { height = fill }
                use blk_nav_icon("⌘")
                use blk_nav_icon("?")
                use blk_nav_icon("⚙")
                use blk_nav_icon("👤")
            }

            // === Sidebar — search + pages tree + indicator types ===
            // Note: no workspace chip. Org is the workspace boundary; there's
            // exactly one workspace per org and the user never needs to choose.
            frame sidebar {
                width = 280, height = fill, fill = #F6F8FA, stroke = [1, #D0D7DE]
                layout = vertical

                // Search (triggers the ⌘K SearchPanel on focus/click)
                frame top_area {
                    width = fill, padding = 12, layout = vertical, gap = 8

                    frame search {
                        width = fill, height = 30, padding = [0, 10], radius = 6
                        fill = #FFFFFF, stroke = [1, #D0D7DE]
                        layout = horizontal, align = center, gap = 8
                        text "🔍" { size = 12, color = #868F99 }
                        text "Search blocks · semantic · ⌘K" { size = 12, color = #868F99 }
                    }
                }

                // === Pages tree ===
                // Rooted at workspace.root_block_id. Nested pages are discovered
                // by walking nest refs and picking children whose block.type = "page".
                frame pages_header {
                    width = fill, padding = [4, 16, 6, 16]
                    layout = horizontal, justify = space-between, align = center
                    text "PAGES" { size = 10, weight = semibold, color = #868F99, text-transform = uppercase, letter-spacing = 1.5 }
                    text "+" { size = 14, color = #656D76 }
                }
                frame pages_tree {
                    width = fill, padding = [0, 4], layout = vertical, gap = 1

                    // Root page (workspace.root_block_id) — always present.
                    use page_node("📖", "Home", 0, #E4E9EE)
                    // Nested pages via nest refs (block.type = "page").
                    use page_node("◆",  "Q4 OKRs",        12, transparent)
                    use page_node("◆",  "Weekly standup", 12, transparent)
                    use page_node("◆",  "Incident log",   12, transparent)
                    use page_node("◆",  "Runbooks",       12, transparent)
                    use page_node("◆",  "Decision log",   12, transparent)
                }

                // === Indicator types (block_type_def) ===
                // Dynamic. Populated from useBlockTypeSpec / listTypeDefs.
                // Count = number of block instances with that type in the workspace.
                frame types_header {
                    width = fill, padding = [16, 16, 6, 16]
                    layout = horizontal, justify = space-between, align = center
                    text "INDICATOR TYPES" { size = 10, weight = semibold, color = #868F99, text-transform = uppercase, letter-spacing = 1.5 }
                    text "+" { size = 14, color = #656D76 }
                }
                frame types_list {
                    width = fill, padding = [0, 16], layout = vertical, gap = 4

                    use type_row(#8250DF, "okr",      "12")
                    use type_row(#1A7F37, "task",     "48")
                    use type_row(#D29922, "incident", "3")
                    use type_row(#0969DA, "metric",   "6")
                }

                frame spacer { height = fill }

                // Triggers — trigger_def block type is implemented; count comes
                // from `block.type = "trigger_def"` in the workspace.
                frame sidebar_footer {
                    width = fill, padding = [10, 12], stroke = [1, #D0D7DE]
                    layout = horizontal, align = center, gap = 8
                    text "Triggers · 7 active" { size = 12, color = #656D76 }
                    frame spacer_r { width = fill }
                    frame more { width = 24, height = 22, radius = 4
                        layout = horizontal, justify = center, align = center
                        text "⋯" { size = 14, weight = semibold, color = #656D76 }
                    }
                }
            }

            // === Main: document editor for the currently selected page ===
            frame main {
                width = fill, height = fill, fill = #FFFFFF, layout = vertical

                // Doc header — breadcrumb + title + primary CTA.
                // No "Default Workspace" chip here: org = workspace, the only
                // context the breadcrumb needs is the page path.
                frame doc_header {
                    width = fill, padding = [16, 48, 8, 48]
                    layout = vertical, gap = 6

                    frame bc {
                        layout = horizontal, gap = 8, align = center
                        text "Pages"        { size = 12, color = #868F99 }
                        text "›"            { size = 12, color = #AFB8C1 }
                        text "Home"         { size = 12, color = #868F99 }
                        text "›"            { size = 12, color = #AFB8C1 }
                        text "Team Dashboard"{ size = 12, weight = medium, color = #1F2328 }
                    }
                    frame title_row {
                        width = fill, layout = horizontal, justify = space-between, align = center

                        frame title_stack { layout = horizontal, gap = 10, align = center
                            text "📖" { size = 22 }
                            text "Team Dashboard" { size = 26, weight = semibold, color = #1F2328 }
                        }
                        frame actions { layout = horizontal, gap = 8, align = center
                            frame btn_add {
                                height = 30, padding = [0, 14], radius = 6, fill = #0969DA
                                layout = horizontal, justify = center, align = center, gap = 6
                                text "+"     { size = 13, weight = medium, color = #FFFFFF }
                                text "Block" { size = 13, weight = medium, color = #FFFFFF }
                            }
                        }
                    }
                }

                shape hrd { type = rectangle, width = 1572, height = 1, fill = #E4E9EE }

                // Document body — scrollable stream of rendered blocks.
                frame doc_body {
                    width = fill, height = fill, padding = [16, 48]
                    layout = vertical, gap = 16

                    // heading-2
                    text "This quarter at a glance" { size = 19, weight = semibold, color = #1F2328 }

                    // paragraph
                    text "Everything below is live — OKRs, tasks, metrics update via the block store. Agents can edit these too."
                        { size = 13, color = #656D76, wrap = true, width = 1550, line-height = 20 }

                    // summary row (3 KPI cards) — `summary` block, summary_columns aggregation
                    frame summary_row {
                        width = fill, layout = horizontal, gap = 16

                        use kpi_card("OKRs on track", "9 of 12", "+2 this week", #1A7F37, #DAFBE1)
                        use kpi_card("Open tickets",  "23",      "−4 vs last week", #1A7F37, #F6F8FA)
                        use kpi_card("Incidents this month", "3",   "stable",         #656D76, #FFF8C5)
                    }

                    // heading-3
                    text "Q4 OKRs · view block" { size = 15, weight = semibold, color = #1F2328, padding = [8, 0, 0, 0] }

                    // view block (table) — layout switcher: Table / Kanban / Timeline / Tree / Gallery
                    frame view_block {
                        width = fill, radius = 8
                        stroke = [1, #D0D7DE]
                        layout = vertical, gap = 0
                        fill = #FFFFFF

                        frame view_tb {
                            width = fill, padding = [8, 12]
                            fill = #F6F8FA
                            layout = horizontal, justify = space-between, align = center

                            frame left { layout = horizontal, gap = 8, align = center
                                frame layout_switch {
                                    padding = 2, radius = 6, fill = #FFFFFF, stroke = [1, #D0D7DE]
                                    layout = horizontal, gap = 0
                                    frame t { padding = [3, 8], radius = 4, fill = #E4E9EE
                                        text "Table"    { size = 11, weight = medium, color = #1F2328 }
                                    }
                                    frame k { padding = [3, 8], radius = 4
                                        text "Kanban"   { size = 11, color = #656D76 }
                                    }
                                    frame l { padding = [3, 8], radius = 4
                                        text "Timeline" { size = 11, color = #656D76 }
                                    }
                                    frame tr { padding = [3, 8], radius = 4
                                        text "Tree"     { size = 11, color = #656D76 }
                                    }
                                    frame g { padding = [3, 8], radius = 4
                                        text "Gallery"  { size = 11, color = #656D76 }
                                    }
                                }
                                text "type:okr" { size = 11, color = #0550AE, family = "JetBrains Mono" }
                                text "filter: quarter=Q4" { size = 11, color = #656D76, family = "JetBrains Mono" }
                                text "sort: progress desc" { size = 11, color = #656D76, family = "JetBrains Mono" }
                            }
                            text "Edit view →" { size = 12, color = #0969DA }
                        }

                        frame th {
                            width = fill, padding = [6, 8]
                            fill = #FAFBFC, stroke = [1, #E4E9EE]
                            layout = horizontal, gap = 0
                            use table_cell("Objective",       620)
                            use table_cell("Owner",           180)
                            use table_cell("Progress",        280)
                            use table_cell("Status",          160)
                            use table_cell("Quarter",         140)
                        }

                        frame r1 { width = fill, layout = horizontal, stroke = [0, transparent]
                            use table_cell("Ship authentication v2",    620)
                            use table_cell("Dev User",                  180)
                            frame prog_cell { width = 280, padding = [8, 10], layout = vertical, gap = 2, justify = center
                                frame bar_bg { width = 200, height = 6, radius = 3, fill = #E4E9EE
                                    frame bar_fg { width = 170, height = 6, radius = 3, fill = #1A7F37 }
                                }
                                text "85%" { size = 11, color = #1A7F37, family = "JetBrains Mono" }
                            }
                            frame st { width = 160, padding = [8, 10]
                                frame pill { padding = [1, 8], radius = 999, fill = #DAFBE1
                                    text "on track" { size = 10, weight = medium, color = #1A7F37 }
                                }
                            }
                            use table_cell("Q4 2026",                   140)
                        }
                        frame r2 { width = fill, layout = horizontal
                            use table_cell("Launch Block Store GA",     620)
                            use table_cell("Sam",                       180)
                            frame prog_cell { width = 280, padding = [8, 10], layout = vertical, gap = 2, justify = center
                                frame bar_bg { width = 200, height = 6, radius = 3, fill = #E4E9EE
                                    frame bar_fg { width = 100, height = 6, radius = 3, fill = #D29922 }
                                }
                                text "50%" { size = 11, color = #D29922, family = "JetBrains Mono" }
                            }
                            frame st { width = 160, padding = [8, 10]
                                frame pill { padding = [1, 8], radius = 999, fill = #FFF8C5
                                    text "at risk" { size = 10, weight = medium, color = #9A6700 }
                                }
                            }
                            use table_cell("Q4 2026",                   140)
                        }
                        frame r3 { width = fill, layout = horizontal
                            use table_cell("Runner at-capacity incidents → 0", 620)
                            use table_cell("Maria",                     180)
                            frame prog_cell { width = 280, padding = [8, 10], layout = vertical, gap = 2, justify = center
                                frame bar_bg { width = 200, height = 6, radius = 3, fill = #E4E9EE
                                    frame bar_fg { width = 40, height = 6, radius = 3, fill = #CF222E }
                                }
                                text "20%" { size = 11, color = #CF222E, family = "JetBrains Mono" }
                            }
                            frame st { width = 160, padding = [8, 10]
                                frame pill { padding = [1, 8], radius = 999, fill = #FFEBE9
                                    text "off track" { size = 10, weight = medium, color = #CF222E }
                                }
                            }
                            use table_cell("Q4 2026",                   140)
                        }

                        frame view_footer {
                            width = fill, padding = [6, 12]
                            fill = #FAFBFC, stroke = [1, #E4E9EE]
                            layout = horizontal, gap = 16, align = center

                            text "3 rows"             { size = 11, color = #868F99, family = "JetBrains Mono" }
                            text "avg(progress) = 52%" { size = 11, color = #868F99, family = "JetBrains Mono" }
                            frame spacer { width = fill }
                            text "+ Add OKR" { size = 12, weight = medium, color = #0969DA }
                        }
                    }

                    // heading-3
                    text "Weekly tasks · task block list" { size = 15, weight = semibold, color = #1F2328, padding = [8, 0, 0, 0] }

                    // task block list
                    frame tasks_block {
                        width = fill, layout = vertical, gap = 2
                        use task_row(#1A7F37, "Wire up the credential profile fallback path",   "done",   #DAFBE1, #1A7F37, "D", #0969DA)
                        use task_row(#D29922, "Draft migration 000124: block_embeddings gin idx","in_progress", #FFF8C5, #9A6700, "S", #9A6700)
                        use task_row(#FFFFFF, "Audit runner-staging offline alerts",            "todo",   #F6F8FA, #656D76, "M", #8250DF)
                        use task_row(#FFFFFF, "Draft Q1 OKR candidates — share by Friday",     "todo",   #F6F8FA, #656D76, "D", #0969DA)
                    }

                    // Slash menu hint
                    frame hint {
                        padding = [12, 0, 0, 0]
                        layout = horizontal, gap = 6, align = center
                        frame k { padding = [1, 6], radius = 4, fill = #F6F8FA, stroke = [1, #D0D7DE]
                            text "/" { size = 10, color = #656D76, family = "JetBrains Mono" }
                        }
                        text "to insert a block · type it anywhere"
                            { size = 11, color = #B1B7BE }
                    }
                }
            }
        }
    }
}


component pg_blocks_document_framed() {
    frame outer {
        width = 2000
        height = 1160
        fill = #1F2328
        padding = 40
        layout = horizontal
        justify = center
        align = center
        use pg_blocks_document()
    }
}

frame root {
    use pg_blocks_document_framed()
}
