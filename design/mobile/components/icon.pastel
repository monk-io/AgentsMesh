// Mobile icons — lucide PNG assets generated by scripts/gen-icons.sh.
// Pastel `shape { type = path }` proved unreliable when nested inside layout
// frames (rect.w collapses to 0). PNG via `asset image` + `image` node renders
// reliably and gives us 1:1 lucide visual parity with clients/web.
//
// Source SVGs in scripts/gen-icons.sh — re-run that to regenerate after edits.

asset terminal_blue   = image("../assets/lucide-png/terminal-0969DA.png")
asset terminal_gray   = image("../assets/lucide-png/terminal-8E8E93.png")
asset terminal_dark   = image("../assets/lucide-png/terminal-6E7681.png")
asset terminal_filled = image("../assets/lucide-png/terminal-filled-0969DA.png")

asset message_blue    = image("../assets/lucide-png/message-0969DA.png")
asset message_gray    = image("../assets/lucide-png/message-8E8E93.png")
asset message_dark    = image("../assets/lucide-png/message-6E7681.png")
asset message_filled  = image("../assets/lucide-png/message-filled-0969DA.png")

asset ticket_blue     = image("../assets/lucide-png/ticket-0969DA.png")
asset ticket_gray     = image("../assets/lucide-png/ticket-8E8E93.png")
asset ticket_dark     = image("../assets/lucide-png/ticket-6E7681.png")
asset ticket_filled   = image("../assets/lucide-png/ticket-filled-0969DA.png")

asset blocks_blue     = image("../assets/lucide-png/blocks-0969DA.png")
asset blocks_gray     = image("../assets/lucide-png/blocks-8E8E93.png")
asset blocks_dark     = image("../assets/lucide-png/blocks-6E7681.png")
asset blocks_filled   = image("../assets/lucide-png/blocks-filled-0969DA.png")

asset ellipsis_blue   = image("../assets/lucide-png/ellipsis-0969DA.png")
asset ellipsis_gray   = image("../assets/lucide-png/ellipsis-8E8E93.png")
asset ellipsis_dark   = image("../assets/lucide-png/ellipsis-6E7681.png")

asset search_blue     = image("../assets/lucide-png/search-0969DA.png")
asset plus_blue       = image("../assets/lucide-png/plus-0969DA.png")
asset back_blue       = image("../assets/lucide-png/back-0969DA.png")
asset back_dark       = image("../assets/lucide-png/back-58A6FF.png")
asset cog_blue        = image("../assets/lucide-png/cog-0969DA.png")
asset cog_dark        = image("../assets/lucide-png/cog-8B949E.png")
asset close_gray      = image("../assets/lucide-png/close-8E8E93.png")
asset close_dark      = image("../assets/lucide-png/close-C9D1D9.png")

canvas "ios_icons" {
    width = 1100
    height = 920
    background = #1F2328
}

component pg_icons() {
frame root {
    stroke = [2, #6E7681]
    radius = 16
    shadow = [0, 8, 24, #00000080]
    width = 1020, height = 860, fill = #FFFFFF
    padding = 32, layout = vertical, gap = 24

    text "Mobile Icons (lucide PNG assets)" { size = 24, weight = semibold, color = #1F2328 }
    text "Generated from real lucide SVG paths via rsvg-convert. 1:1 visual parity with clients/web's lucide-react. Re-run scripts/gen-icons.sh after path edits."
        { size = 13, color = #656D76, wrap = true, width = 920 }

    // Outline row
    text "TAB ICONS · OUTLINE" { size = 11, weight = semibold, color = #6E7681, letter-spacing = 1.5 }

    frame outline_row {
        width = fill, layout = horizontal, gap = 12, justify = start

        frame c1 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatches { layout = horizontal, gap = 16, align = center
                frame s1 { width = 44, height = 44, radius = 8, fill = #B6E3FF
                    layout = horizontal, justify = center, align = center
                    image terminal_blue { width = 24, height = 24 }
                }
                frame s2 { width = 44, height = 44, radius = 8, fill = #FFFFFF
                    layout = horizontal, justify = center, align = center
                    image terminal_gray { width = 24, height = 24 }
                }
            }
            text "icon_pods" { size = 11, weight = semibold, color = #1F2328 }
            text "Pods (Terminal)" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame c2 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatches { layout = horizontal, gap = 16, align = center
                frame s1 { width = 44, height = 44, radius = 8, fill = #B6E3FF
                    layout = horizontal, justify = center, align = center
                    image message_blue { width = 24, height = 24 }
                }
                frame s2 { width = 44, height = 44, radius = 8, fill = #FFFFFF
                    layout = horizontal, justify = center, align = center
                    image message_gray { width = 24, height = 24 }
                }
            }
            text "icon_message_square" { size = 11, weight = semibold, color = #1F2328 }
            text "Channels" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame c3 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatches { layout = horizontal, gap = 16, align = center
                frame s1 { width = 44, height = 44, radius = 8, fill = #B6E3FF
                    layout = horizontal, justify = center, align = center
                    image ticket_blue { width = 24, height = 24 }
                }
                frame s2 { width = 44, height = 44, radius = 8, fill = #FFFFFF
                    layout = horizontal, justify = center, align = center
                    image ticket_gray { width = 24, height = 24 }
                }
            }
            text "icon_ticket" { size = 11, weight = semibold, color = #1F2328 }
            text "Tickets" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame c4 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatches { layout = horizontal, gap = 16, align = center
                frame s1 { width = 44, height = 44, radius = 8, fill = #B6E3FF
                    layout = horizontal, justify = center, align = center
                    image blocks_blue { width = 24, height = 24 }
                }
                frame s2 { width = 44, height = 44, radius = 8, fill = #FFFFFF
                    layout = horizontal, justify = center, align = center
                    image blocks_gray { width = 24, height = 24 }
                }
            }
            text "icon_blocks" { size = 11, weight = semibold, color = #1F2328 }
            text "Blocks" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame c5 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatches { layout = horizontal, gap = 16, align = center
                frame s1 { width = 44, height = 44, radius = 8, fill = #B6E3FF
                    layout = horizontal, justify = center, align = center
                    image ellipsis_blue { width = 24, height = 24 }
                }
                frame s2 { width = 44, height = 44, radius = 8, fill = #FFFFFF
                    layout = horizontal, justify = center, align = center
                    image ellipsis_gray { width = 24, height = 24 }
                }
            }
            text "icon_more" { size = 11, weight = semibold, color = #1F2328 }
            text "More" { size = 10, color = #868F99, family = "SF Mono" }
        }
    }

    text "TAB ICONS · FILLED (active state)" { size = 11, weight = semibold, color = #6E7681, letter-spacing = 1.5 }

    frame filled_row {
        width = fill, layout = horizontal, gap = 12, justify = start

        frame c1 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, radius = 8, fill = #B6E3FF
                layout = horizontal, justify = center, align = center
                image terminal_filled { width = 24, height = 24 }
            }
            text "icon_pods_filled" { size = 11, weight = semibold, color = #1F2328 }
        }
        frame c2 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, radius = 8, fill = #B6E3FF
                layout = horizontal, justify = center, align = center
                image message_filled { width = 24, height = 24 }
            }
            text "icon_message_filled" { size = 11, weight = semibold, color = #1F2328 }
        }
        frame c3 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, radius = 8, fill = #B6E3FF
                layout = horizontal, justify = center, align = center
                image ticket_filled { width = 24, height = 24 }
            }
            text "icon_ticket_filled" { size = 11, weight = semibold, color = #1F2328 }
        }
        frame c4 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, radius = 8, fill = #B6E3FF
                layout = horizontal, justify = center, align = center
                image blocks_filled { width = 24, height = 24 }
            }
            text "icon_blocks_filled" { size = 11, weight = semibold, color = #1F2328 }
        }
        frame c5 {
            width = 180, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, radius = 8, fill = #B6E3FF
                layout = horizontal, justify = center, align = center
                image ellipsis_blue { width = 24, height = 24 }
            }
            text "icon_more_filled" { size = 11, weight = semibold, color = #1F2328 }
        }
    }

    text "NAV ACTION ICONS" { size = 11, weight = semibold, color = #6E7681, letter-spacing = 1.5 }

    frame nav_row {
        width = fill, layout = horizontal, gap = 12, justify = start, align = center

        frame n1 {
            width = 100, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image search_blue { width = 24, height = 24 }
            }
            text "search" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame n2 {
            width = 100, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image plus_blue { width = 24, height = 24 }
            }
            text "plus" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame n3 {
            width = 100, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image back_blue { width = 24, height = 24 }
            }
            text "back" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame n4 {
            width = 100, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image cog_blue { width = 24, height = 24 }
            }
            text "cog" { size = 10, color = #868F99, family = "SF Mono" }
        }
        frame n5 {
            width = 100, padding = 12, radius = 12, fill = #F6F8FA
            layout = vertical, gap = 8, align = center
            frame swatch { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image close_gray { width = 24, height = 24 }
            }
            text "close" { size = 10, color = #868F99, family = "SF Mono" }
        }
    }
}
}


component pg_icons_framed() {
    frame outer {
        width = 1100, height = 920, fill = #1F2328
        padding = 40, layout = horizontal, justify = center, align = center
        use pg_icons()
    }
}

frame root { use pg_icons_framed() }
