// iOS 26 Floating Tab Bar — capsule, glass material, 16pt above safe-bottom.
// Width = 393 - 32 (16pt edge insets) = 361pt. Height 56pt.
// Active tab uses filled lucide PNG + #0969DA. Inactive uses outline + #8E8E93.
// Icons are PNG assets generated by scripts/gen-icons.sh (see icon.pastel for rationale).

asset terminal_active   = image("../assets/lucide-png/terminal-filled-0969DA.png")
asset terminal_inactive = image("../assets/lucide-png/terminal-8E8E93.png")
asset terminal_dark     = image("../assets/lucide-png/terminal-6E7681.png")
asset message_active    = image("../assets/lucide-png/message-filled-0969DA.png")
asset message_inactive  = image("../assets/lucide-png/message-8E8E93.png")
asset message_dark      = image("../assets/lucide-png/message-6E7681.png")
asset ticket_active     = image("../assets/lucide-png/ticket-filled-0969DA.png")
asset ticket_inactive   = image("../assets/lucide-png/ticket-8E8E93.png")
asset ticket_dark       = image("../assets/lucide-png/ticket-6E7681.png")
asset blocks_active     = image("../assets/lucide-png/blocks-filled-0969DA.png")
asset blocks_inactive   = image("../assets/lucide-png/blocks-8E8E93.png")
asset blocks_dark       = image("../assets/lucide-png/blocks-6E7681.png")
asset more_active       = image("../assets/lucide-png/ellipsis-0969DA.png")
asset more_inactive     = image("../assets/lucide-png/ellipsis-8E8E93.png")
asset more_dark         = image("../assets/lucide-png/ellipsis-6E7681.png")

canvas "ios_tab_bar" {
    width = 920
    height = 760
    background = #1F2328
}

// ── Tab cells ──────────────────────────────────────────────────────

component tab_pods_active() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64
        image terminal_active { width = 24, height = 24 }
        text "Pods" { size = 10, weight = semibold, color = #0969DA, family = "SF Pro" }
    }
}
component tab_pods_inactive() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64
        image terminal_inactive { width = 24, height = 24 }
        text "Pods" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
    }
}
component tab_channels_inactive() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64
        image message_inactive { width = 24, height = 24 }
        text "Channels" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
    }
}
component tab_tickets_inactive() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64
        image ticket_inactive { width = 24, height = 24 }
        text "Tickets" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
    }
}
component tab_blocks_inactive() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64
        image blocks_inactive { width = 24, height = 24 }
        text "Blocks" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
    }
}
component tab_more_inactive() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64
        image more_inactive { width = 24, height = 24 }
        text "More" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
    }
}

// ── Floating tab bar (default, Pods active) ────────────────────────

component tab_bar_pods_active() {
    frame {
        width = 361, height = 56, radius = 28
        fill = #FFFFFFE6
        stroke = [1, #0000000D]
        shadow = [0, 4, 12, #00000014]
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        use tab_pods_active()
        use tab_channels_inactive()
        use tab_tickets_inactive()
        use tab_blocks_inactive()
        use tab_more_inactive()
    }
}

// ── With unread badge on Channels ──────────────────────────────────

component tab_channels_with_badge() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64

        frame icon_wrap {
            layout = horizontal, justify = center, align = center
            image message_inactive { width = 24, height = 24 }
            frame badge {
                width = 18, height = 18, radius = 999, fill = #CF222E
                stroke = [1.5, #FFFFFF]
                layout = horizontal, justify = center, align = center
                text "3" { size = 11, weight = semibold, color = #FFFFFF }
            }
        }
        text "Channels" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
    }
}

component tab_bar_with_badge() {
    frame {
        width = 361, height = 56, radius = 28
        fill = #FFFFFFE6
        stroke = [1, #0000000D]
        shadow = [0, 4, 12, #00000014]
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        use tab_pods_inactive()
        use tab_channels_with_badge()
        use tab_tickets_inactive()
        use tab_blocks_inactive()
        use tab_more_inactive()
    }
}

// ── Dark variant (used over terminal full-screen) ──────────────────

component tab_pods_active_dark() {
    frame { layout = vertical, gap = 2, align = center, justify = center
        padding = [4, 0], width = 64
        image terminal_active { width = 24, height = 24 }
        text "Pods" { size = 10, weight = semibold, color = #58A6FF, family = "SF Pro" }
    }
}
component tab_dark_inactive(asset_name, label) {
    frame { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
        image asset_name { width = 24, height = 24 }
        text label { size = 10, weight = medium, color = #6E7681, family = "SF Pro" }
    }
}

component tab_bar_dark() {
    frame {
        width = 361, height = 56, radius = 28
        fill = #1F2328E6
        stroke = [1, #30363D]
        shadow = [0, 4, 12, #00000040]
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        use tab_pods_active_dark()
        frame d1 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image message_dark { width = 24, height = 24 }
            text "Channels" { size = 10, weight = medium, color = #6E7681, family = "SF Pro" }
        }
        frame d2 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image ticket_dark { width = 24, height = 24 }
            text "Tickets" { size = 10, weight = medium, color = #6E7681, family = "SF Pro" }
        }
        frame d3 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image blocks_dark { width = 24, height = 24 }
            text "Blocks" { size = 10, weight = medium, color = #6E7681, family = "SF Pro" }
        }
        frame d4 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image more_dark { width = 24, height = 24 }
            text "More" { size = 10, weight = medium, color = #6E7681, family = "SF Pro" }
        }
    }
}

component label(text_value) {
    text text_value { size = 11, weight = semibold, color = #6E7681, letter-spacing = 1.5 }
}

component pg_tab_bar() {
frame root {
    stroke = [2, #6E7681]
    radius = 16
    shadow = [0, 8, 24, #00000080]
    width = 840, height = 700, fill = #F2F2F7
    padding = 32, layout = vertical, gap = 20

    text "Floating Tab Bar (iOS 26)" { size = 24, weight = semibold, color = #1F2328 }
    text "Capsule shape, radius 28pt. 361pt × 56pt — sits 16pt above home indicator. Filled icon + bold label = active. Outline icon + medium label = inactive. Glass background #FFFFFFE6."
        { size = 13, color = #656D76, wrap = true, width = 740 }

    frame v1 { layout = vertical, gap = 12
        use label("DEFAULT — Pods active")
        frame center { width = fill, layout = horizontal, justify = center, use tab_bar_pods_active() }
    }

    frame v2 { layout = vertical, gap = 12
        use label("WITH UNREAD BADGE — Channels has 3")
        frame center { width = fill, layout = horizontal, justify = center, use tab_bar_with_badge() }
    }

    frame v3 { layout = vertical, gap = 12
        use label("DARK VARIANT — used when content is dark (terminal full-screen)")
        frame center { width = fill, padding = 16, fill = #0D1117, radius = 12, layout = horizontal, justify = center
            use tab_bar_dark()
        }
    }
}
}


component pg_tab_bar_framed() {
    frame outer {
        width = 920, height = 760, fill = #1F2328
        padding = 40, layout = horizontal, justify = center, align = center
        use pg_tab_bar()
    }
}

frame root { use pg_tab_bar_framed() }
