// iOS sitemap — 5-tab IA + NavigationStack + modal/sheet overview.
// Updated to reflect: Workspace → Pods rename · Pods grid (Chrome tab switcher) · drawer (Lark)

canvas "ios_sitemap" {
    width = 1880
    height = 2200
    background = #1F2328
}

component sm_section_label(label) {
    text label {
        size = 11, weight = semibold, color = #656D76
        text-transform = uppercase, letter-spacing = 1.5
    }
}

component tab_root(icon, label, route) {
    frame {
        width = 320, padding = [10, 12], radius = 12
        fill = #DDF4FF, stroke = [1, #0969DA]
        layout = horizontal, align = center, gap = 10

        text icon { size = 16, color = #0969DA }
        frame stack { layout = vertical, gap = 1
            text label { size = 14, weight = semibold, color = #0550AE }
            text route { size = 11, color = #0969DA, family = "SF Mono" }
        }
    }
}

component push_item(label, route) {
    frame {
        width = 320, padding = [6, 12, 6, 28]
        layout = vertical, gap = 1

        text label { size = 13, weight = normal, color = #1F2328 }
        text route { size = 11, color = #868F99, family = "SF Mono" }
    }
}

component modal_item(label, kind) {
    frame {
        width = 320, padding = [6, 12, 6, 28]
        layout = vertical, gap = 1

        frame head {
            layout = horizontal, gap = 6, align = center
            frame badge { padding = [1, 6], radius = 4, fill = #FFF8C5
                text kind { size = 10, weight = medium, color = #9A6700, family = "SF Mono" }
            }
            text label { size = 13, weight = medium, color = #1F2328 }
        }
    }
}

component col_header(title, subtitle) {
    frame {
        layout = vertical, gap = 2, padding = [0, 0, 4, 0]
        text title    { size = 16, weight = semibold, color = #1F2328 }
        text subtitle { size = 12, color = #656D76 }
    }
}

component cut_row(label, reason) {
    frame {
        width = fill, padding = [4, 0]
        layout = vertical, gap = 2

        frame head {
            layout = horizontal, gap = 6, align = center
            text "✕" { size = 12, weight = semibold, color = #CF222E }
            text label { size = 13, weight = medium, color = #1F2328 }
        }
        text reason { size = 12, color = #656D76, wrap = true, width = 380, line-height = 16 }
    }
}

component pg_ios_sitemap() {
frame root {
    stroke = [2, #6E7681], radius = 16
    shadow = [0, 8, 24, #00000080]
    width = 1800, height = 2120, fill = #FFFFFF
    padding = 48, layout = vertical, gap = 28

    // Header
    frame header {
        layout = vertical, gap = 4
        text "iOS — Information Architecture (v2)" { size = 24, weight = semibold, color = #1F2328 }
        text "Bottom TabBar (5) + per-tab NavigationStack. Avatar in nav-bar opens left drawer (Lark / Slack multi-workspace pattern). Pods tab uses Chrome iOS Tab Switcher grid layout."
            { size = 13, color = #656D76, wrap = true, width = 1400 }
    }

    // Top chrome
    frame chrome {
        width = fill, padding = 16, radius = 12
        fill = #F6F8FA, stroke = [1, #D0D7DE]
        layout = vertical, gap = 10

        use sm_section_label("Global chrome (every tab root)")

        frame chrome_visual {
            width = 480, height = 64, radius = 12
            fill = #FFFFFF, stroke = [1, #D0D7DE]
            padding = [10, 12]
            layout = horizontal, justify = space-between, align = center

            frame left { layout = horizontal, gap = 12, align = center
                frame avatar { width = 40, height = 40, radius = 999, fill = #0969DA
                    layout = horizontal, justify = center, align = center
                    text "S" { size = 17, weight = semibold, color = #FFFFFF }
                }
                text "Pods" { size = 17, weight = semibold, color = #1F2328 }
            }

            frame right { layout = horizontal, gap = 8, align = center
                text "⌕" { size = 17, color = #0969DA }
                text "+" { size = 18, weight = medium, color = #0969DA }
            }
        }

        text "[Avatar (drawer entry)]  ·  [Page title]  ·  [Search / Plus]" { size = 12, color = #868F99, family = "SF Mono" }
    }

    // Tabs grid
    frame tab_grid {
        width = fill, layout = horizontal, gap = 60, align = start

        // LEFT — Pods + Channels + Tickets
        frame left_col {
            layout = vertical, gap = 24, width = 820

            use col_header("Tabs 1–3", "Daily-work surfaces — Pod execution + collaboration + task tracking")

            use sm_section_label("Tab 1 · Pods (was Workspace)")
            frame ws { layout = vertical, gap = 6
                use tab_root(">_", "Pods", "/pods")
                use push_item("Pod grid (Chrome tab switcher · default view)",  "PodGridView · root")
                use push_item("Pod list (alternative view)",                    "PodListView · segment toggle")
                use push_item("Terminal (PTY or ACP)",                           "TerminalView · push, hides tab bar")
                use modal_item("Create Pod", "sheet")
                use modal_item("Org Drawer", "left-slide drawer")
            }

            use sm_section_label("Tab 2 · Channels")
            frame ch { layout = vertical, gap = 6
                use tab_root("#", "Channels", "/channels")
                use push_item("Channel list (Active / Linked / Quiet)", "ChannelListView · root")
                use push_item("Channel detail (chat + tool cards)", "ChannelDetailView · push")
                use modal_item("New Channel", "sheet")
            }

            use sm_section_label("Tab 3 · Tickets")
            frame tk { layout = vertical, gap = 6
                use tab_root("🎫", "Tickets", "/tickets")
                use push_item("Ticket list / Board (segment)", "TicketListView · root")
                use push_item("Ticket detail (Details / Pods / Activity tabs)", "TicketDetailView · push")
                use modal_item("Spawn Pod from Ticket", "sheet → reuses Create Pod")
            }
        }

        // RIGHT — Blocks + More + cuts
        frame right_col {
            layout = vertical, gap = 24, width = 820

            use col_header("Tabs 4–5", "Knowledge + everything else")

            use sm_section_label("Tab 4 · Blocks")
            frame bl { layout = vertical, gap = 6
                use tab_root("▦", "Blocks", "/blocks")
                use push_item("Block list (Recent / Pinned / Tree)", "BlockListView · root")
                use push_item("Block detail (read-only)", "BlockDetailView · push")
                use modal_item("Edit on desktop hint", "sheet")
            }

            use sm_section_label("Tab 5 · More")
            frame more { layout = vertical, gap = 6
                use tab_root("⋯", "More", "/more")
                use push_item("Mesh — runner-grouped pod list (no topology graph)", "MeshListView · push")
                use push_item("Loops — list + run history (read-only)", "LoopListView · push")
                use push_item("Settings · Personal", "PersonalSettings · push")
                use push_item("Settings · Organization", "OrgSettings · push (admin)")
                use push_item("Support Tickets", "SupportListView · push")
                use push_item("About / Privacy", "AboutView · push")
                use modal_item("Logout confirm", "alert")
            }

            // Cuts
            use sm_section_label("Out of scope on iOS")
            frame cuts { width = fill, padding = 12, radius = 12
                fill = #FFEBE9, stroke = [1, #FFC1BC]
                layout = vertical, gap = 10

                use cut_row("Mesh topology graph", "Topology visualization too dense for small screens; iOS shows runner-grouped flat Pod list.")
                use cut_row("Block document editing", "Read-only on mobile. Editing stays on Web/Electron.")
                use cut_row("Loop creation / editing", "Complex form. iOS only views existing loops + run history.")
                use cut_row("Autopilot configuration", "Read-only autopilot status surfaced inside Pod detail.")
            }
        }
    }

    // Summary
    frame summary {
        width = fill, padding = 20, radius = 12
        fill = #DDF4FF, stroke = [1, #0969DA]
        layout = vertical, gap = 8

        text "What changed in v2" { size = 14, weight = semibold, color = #0550AE }
        text "· Tab \"Workspace\" → \"Pods\" — concept simpler; matches the browser-tab metaphor of the new grid view."
            { size = 13, color = #1F2328, wrap = true, width = 1640 }
        text "· Pods tab default view = Chrome iOS Tab Switcher (2-column card grid). Each card has agent icon + pod_key + terminal preview + status chip + close."
            { size = 13, color = #1F2328, wrap = true, width = 1640 }
        text "· Org Switcher promoted from bottom-sheet to LEFT-SLIDE DRAWER (Lark / Slack pattern). Avatar in nav-bar is the entry point."
            { size = 13, color = #1F2328, wrap = true, width = 1640 }
        text "· iOS 26 visual language adopted: Liquid Glass nav/tab background, FLOATING capsule tab bar, larger radii (12 / 22 / 28), filled active icons, soft separators."
            { size = 13, color = #1F2328, wrap = true, width = 1640 }
    }
}
}


component pg_ios_sitemap_framed() {
    frame outer {
        width = 1880, height = 2200, fill = #1F2328
        padding = 40, layout = horizontal, justify = center, align = center
        use pg_ios_sitemap()
    }
}

frame root { use pg_ios_sitemap_framed() }
