// iOS More tab — Tab 5 root.

asset terminal_inactive = image("../assets/lucide-png/terminal-8E8E93.png")
asset message_inactive  = image("../assets/lucide-png/message-8E8E93.png")
asset ticket_inactive   = image("../assets/lucide-png/ticket-8E8E93.png")
asset blocks_inactive   = image("../assets/lucide-png/blocks-8E8E93.png")
asset more_active       = image("../assets/lucide-png/ellipsis-0969DA.png")

canvas "ios_more" {
    width = 1100
    height = 1100
    background = #1F2328
}

component sh_status_bar() {
    frame {
        width = fill, height = 59, fill = #FFFFFF
        layout = horizontal, justify = space-between, align = center, padding = [0, 22]
        text "9:41" { size = 17, weight = semibold, color = #1F2328, family = "SF Pro" }
        frame icons { layout = horizontal, gap = 6, align = center
            text "📶" { size = 14 } text "📡" { size = 14 }
            frame battery { width = 28, height = 13, radius = 4, stroke = [1, #1F2328], padding = 2,
                layout = horizontal, align = center
                shape level { type = rectangle, width = 20, height = 7, radius = 1, fill = #1F2328 }
            }
        }
    }
}

component sh_nav_bar() {
    frame {
        width = fill, height = 44, fill = #FFFFFFE6
        padding = [0, 8, 0, 12], layout = horizontal, justify = space-between, align = center
        frame left { layout = horizontal, gap = 12, align = center
            frame avatar { width = 40, height = 40, radius = 999, fill = #0969DA
                layout = horizontal, justify = center, align = center
                text "S" { size = 17, weight = semibold, color = #FFFFFF }
            }
            text "More" { size = 17, weight = semibold, color = #1F2328 }
        }
        frame spacer { width = 44 }
    }
}

component sh_floating_tab_bar() {
    frame {
        width = 361, height = 56, radius = 28
        fill = #FFFFFFE6, stroke = [1, #0000000D]
        shadow = [0, 4, 12, #00000014]
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        frame t1 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image terminal_inactive { width = 24, height = 24 }
            text "Pods" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t2 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image message_inactive { width = 24, height = 24 }
            text "Channels" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t3 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image ticket_inactive { width = 24, height = 24 }
            text "Tickets" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t4 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image blocks_inactive { width = 24, height = 24 }
            text "Blocks" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t5 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image more_active { width = 24, height = 24 }
            text "More" { size = 10, weight = semibold, color = #0969DA, family = "SF Pro" }
        }
    }
}

component section_label(label) {
    frame { width = fill, height = 32, padding = [4, 16, 8, 16]
        layout = horizontal, align = end
        text label { size = 13, color = #6D6D72, text-transform = uppercase, letter-spacing = 0.5 }
    }
}

component nav_cell(icon, icon_color, icon_bg, label, sub) {
    frame {
        width = fill, height = 60, padding = [10, 16]
        fill = #FFFFFF
        layout = horizontal, gap = 12, align = center

        frame icon_box { width = 32, height = 32, radius = 8, fill = icon_bg
            layout = horizontal, justify = center, align = center
            text icon { size = 17, color = icon_color }
        }
        frame stack { layout = vertical, gap = 2, width = 250
            text label { size = 17, color = #1F2328 }
            text sub { size = 13, color = #8E8E93 }
        }
        text "›" { size = 22, color = #C7C7CC }
    }
}

component logout_cell() {
    frame {
        width = fill, height = 60, padding = [10, 16]
        fill = #FFFFFF
        layout = horizontal, gap = 12, align = center

        frame icon_box { width = 32, height = 32, radius = 8, fill = #FFEBE9
            layout = horizontal, justify = center, align = center
            text "⏻" { size = 17, color = #CF222E }
        }
        text "Logout" { size = 17, color = #CF222E }
    }
}

component sep() {
    frame { width = fill, height = 1, padding = [0, 0, 0, 60]
        layout = horizontal
        shape line { type = rectangle, width = fill, height = 1, fill = #F2F2F7 }
    }
}

component pg_more() {
frame root {
    width = 393, height = 852, fill = #FFFFFF
    radius = 47, stroke = [3, #1F2328]
    layout = vertical

    use sh_status_bar()
    use sh_nav_bar()

    frame body {
        width = fill, height = fill, fill = #F2F2F7
        padding = [0, 16, 88, 16], layout = vertical, gap = 0

        use section_label("Workspace tools")
        frame card1 { width = fill, radius = 12, fill = #FFFFFF, layout = vertical
            use nav_cell("🕸", #1F2328, #DDF4FF, "Mesh",  "runners · pod-runner relationships")
            use sep()
            use nav_cell("↻",  #1F2328, #DAFBE1, "Loops", "5 active · 23 runs this week")
        }

        use section_label("Settings")
        frame card2 { width = fill, radius = 12, fill = #FFFFFF, layout = vertical
            use nav_cell("⚙", #1F2328, #F0F3F6, "Personal", "general · git · agents · notifications")
            use sep()
            use nav_cell("🏢", #1F2328, #F0F3F6, "Organization", "owner · 12 members · 5 runners")
        }

        use section_label("Help")
        frame card3 { width = fill, radius = 12, fill = #FFFFFF, layout = vertical
            use nav_cell("🆘", #CF222E, #FFEBE9, "Support Tickets", "1 open conversation")
            use sep()
            use nav_cell("ⓘ", #1F2328, #F0F3F6, "About", "version 1.0.0 (build 142)")
        }

        use section_label("Account")
        frame card4 { width = fill, radius = 12, fill = #FFFFFF, layout = vertical
            use logout_cell()
        }
    }

    frame tab_zone {
        width = fill, height = 88, fill = #F2F2F7
        layout = vertical, justify = end, align = center, padding = [0, 0, 16, 0]
        use sh_floating_tab_bar()
    }

    frame safe_bottom { width = fill, height = 34, fill = #F2F2F7
        layout = horizontal, justify = center, align = center
        shape ind { type = rectangle, width = 134, height = 5, radius = 999, fill = #1F2328 }
    }
}
}


component pg_more_framed() {
    frame outer {
        width = 1100, height = 1100, fill = #1F2328
        padding = [60, 80], layout = horizontal, justify = center, align = center
        use pg_more()
    }
}

frame root { use pg_more_framed() }
