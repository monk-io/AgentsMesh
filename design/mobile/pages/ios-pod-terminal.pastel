// iOS Pod Terminal — full-screen push, dark surface.

asset back_dark = image("../assets/lucide-png/back-58A6FF.png")
asset cog_dark  = image("../assets/lucide-png/cog-8B949E.png")

canvas "ios_pod_terminal" {
    width = 1100
    height = 1100
    background = #1F2328
}

component sh_status_bar_dark() {
    frame {
        width = fill, height = 59, fill = #0D1117
        layout = horizontal, justify = space-between, align = center, padding = [0, 22]
        text "9:41" { size = 17, weight = semibold, color = #C9D1D9, family = "SF Pro" }
        frame icons { layout = horizontal, gap = 6, align = center
            text "📶" { size = 14, color = #C9D1D9 } text "📡" { size = 14, color = #C9D1D9 }
            frame battery { width = 28, height = 13, radius = 4, stroke = [1, #C9D1D9], padding = 2,
                layout = horizontal, align = center
                shape level { type = rectangle, width = 20, height = 7, radius = 1, fill = #C9D1D9 }
            }
        }
    }
}

component sh_nav_bar_dark() {
    frame {
        width = fill, height = 44, fill = #0D1117E6
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        frame back { layout = horizontal, gap = 0, align = center
            frame back_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image back_dark { width = 24, height = 24 }
            }
            text "Pods" { size = 17, color = #58A6FF }
        }
        text "pod-abc-123" { size = 17, weight = semibold, color = #C9D1D9, family = "SF Mono" }
        frame cog_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
            image cog_dark { width = 24, height = 24 }
        }
    }
}

component sh_status_strip() {
    frame {
        width = fill, height = 36, padding = [8, 16], fill = #161B22
        layout = horizontal, justify = space-between, align = center

        frame left { layout = horizontal, gap = 8, align = center
            frame dot { width = 8, height = 8, radius = 999, fill = #3FB950 }
            text "running" { size = 13, weight = medium, color = #3FB950, family = "SF Mono" }
            text "·" { size = 13, color = #30363D }
            text "claude-code" { size = 13, color = #C9D1D9, family = "SF Mono" }
            text "·" { size = 13, color = #30363D }
            text "DEV-1" { size = 13, color = #58A6FF }
        }
        frame mode_chip { padding = [2, 8], radius = 4, fill = #0C2D5F
            text "PTY" { size = 11, weight = medium, color = #58A6FF, family = "SF Mono" }
        }
    }
}

component term_line(t, color) { text t { size = 13, color = color, family = "SF Mono" } }

component pg_pod_terminal() {
frame root {
    width = 393, height = 852, fill = #0D1117
    radius = 47, stroke = [3, #1F2328]
    layout = vertical

    use sh_status_bar_dark()
    use sh_nav_bar_dark()
    use sh_status_strip()

    // Native terminal — fills remaining viewport. Tap the surface raises
    // the iOS software keyboard; no app-level composer or send button.
    frame term {
        width = fill, height = fill, fill = #0D1117
        padding = [12, 16], layout = vertical, gap = 4

        use term_line("$ claude-code review src/auth.ts", #C9D1D9)
        use term_line("→ Analyzing authentication flow...", #8B949E)
        use term_line("→ Reading 142 lines from src/auth.ts", #8B949E)
        use term_line("", #8B949E)
        use term_line("Found 2 potential issues:", #C9D1D9)
        use term_line("  1. Missing rate limit on /api/login", #F85149)
        use term_line("  2. JWT secret < 64 bytes", #D29922)
        use term_line("", #8B949E)
        use term_line("$ ls -la migrations/", #C9D1D9)
        use term_line("000001_init.sql", #8B949E)
        use term_line("000002_users.sql", #8B949E)
        use term_line("000003_sessions.sql", #8B949E)
        use term_line("", #8B949E)
        frame cursor_row {
            layout = horizontal, gap = 0, align = center
            text "$ " { size = 13, color = #C9D1D9, family = "SF Mono" }
            shape cursor { type = rectangle, width = 8, height = 16, fill = #3FB950 }
        }
    }

    frame safe_bottom { width = fill, height = 34, fill = #0D1117
        layout = horizontal, justify = center, align = center
        shape ind { type = rectangle, width = 134, height = 5, radius = 999, fill = #C9D1D9 }
    }
}
}


component pg_pod_terminal_framed() {
    frame outer {
        width = 1100, height = 1100, fill = #1F2328
        padding = [60, 80], layout = horizontal, justify = center, align = center
        use pg_pod_terminal()
    }
}

frame root { use pg_pod_terminal_framed() }
