// iOS Channels list — Tab 2 root.
// Lark "消息" pattern: single time-sorted list (no Active/Linked/Quiet sections).
// Each cell:
//   · 56pt rounded-square avatar (radius 12) — colored bg + white hash/emoji
//   · unread badge sits top-right of avatar (absolute overlay)
//   · row 1: title + optional chip (官方 / 机器人 / 外部) + time pushed right
//   · row 2: last-message preview ("who: text" or system text)
// No horizontal separators — spacing alone groups cells.

asset search_blue       = image("../assets/lucide-png/search-0969DA.png")
asset plus_blue         = image("../assets/lucide-png/plus-0969DA.png")
asset terminal_inactive = image("../assets/lucide-png/terminal-8E8E93.png")
asset message_active    = image("../assets/lucide-png/message-filled-0969DA.png")
asset ticket_inactive   = image("../assets/lucide-png/ticket-8E8E93.png")
asset blocks_inactive   = image("../assets/lucide-png/blocks-8E8E93.png")
asset more_inactive     = image("../assets/lucide-png/ellipsis-8E8E93.png")

canvas "ios_channels_list" {
    width = 1100
    height = 1100
    background = #1F2328
}

component sh_status_bar() {
    frame {
        width = fill, height = 59, fill = #FFFFFF
        layout = horizontal, justify = space-between, align = center, padding = [0, 22]
        text "9:41" { size = 17, weight = semibold, color = #1F2328, family = "SF Pro" }
        frame icons { layout = horizontal, gap = 6, align = center
            text "📶" { size = 14 } text "📡" { size = 14 }
            frame battery { width = 28, height = 13, radius = 4, stroke = [1, #1F2328], padding = 2,
                layout = horizontal, align = center
                shape level { type = rectangle, width = 20, height = 7, radius = 1, fill = #1F2328 }
            }
        }
    }
}

component sh_nav_bar() {
    frame {
        width = fill, height = 44, fill = #FFFFFFE6
        padding = [0, 8, 0, 12], layout = horizontal, justify = space-between, align = center
        frame left { layout = horizontal, gap = 12, align = center
            frame avatar { width = 40, height = 40, radius = 999, fill = #0969DA
                layout = horizontal, justify = center, align = center
                text "S" { size = 17, weight = semibold, color = #FFFFFF }
            }
            text "Channels" { size = 17, weight = semibold, color = #1F2328 }
        }
        frame actions { layout = horizontal, gap = 4, align = center
            frame search_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image search_blue { width = 24, height = 24 }
            }
            frame plus_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image plus_blue { width = 24, height = 24 }
            }
        }
    }
}

component sh_floating_tab_bar() {
    frame {
        width = 361, height = 56, radius = 28
        fill = #FFFFFFE6, stroke = [1, #0000000D]
        shadow = [0, 4, 12, #00000014]
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        frame t1 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image terminal_inactive { width = 24, height = 24 }
            text "Pods" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t2 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image message_active { width = 24, height = 24 }
            text "Channels" { size = 10, weight = semibold, color = #0969DA, family = "SF Pro" }
        }
        frame t3 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image ticket_inactive { width = 24, height = 24 }
            text "Tickets" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t4 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image blocks_inactive { width = 24, height = 24 }
            text "Blocks" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t5 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image more_inactive { width = 24, height = 24 }
            text "More" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
    }
}

// ── Avatar with optional unread badge top-right ────────────────────
component avatar(content, bg) {
    frame {
        width = 56, height = 56, radius = 12, fill = bg
        layout = horizontal, justify = center, align = center
        text content { size = 26, weight = semibold, color = #FFFFFF, family = "SF Mono" }
    }
}

component avatar_emoji(emoji, bg) {
    frame {
        width = 56, height = 56, radius = 12, fill = bg
        layout = horizontal, justify = center, align = center
        text emoji { size = 28 }
    }
}

component avatar_outline(letter, bg, color) {
    frame {
        width = 56, height = 56, radius = 12, fill = bg, stroke = [1.5, color]
        layout = horizontal, justify = center, align = center
        text letter { size = 22, weight = semibold, color = color, family = "SF Mono" }
    }
}

// Avatar wrapper that overlays unread badge at top-right corner
component avatar_with_badge(content, bg, count) {
    frame {
        width = 60, height = 60   // 56 avatar + 4pt for badge overflow
        layout = horizontal, justify = start, align = start
        // Avatar offset 4pt from top-left so badge can overflow top-right
        frame av_wrap {
            width = 60, height = 60
            layout = horizontal, justify = start, align = end   // place avatar at bottom-left
            frame av { width = 56, height = 56, radius = 12, fill = bg
                layout = horizontal, justify = center, align = center
                text content { size = 26, weight = semibold, color = #FFFFFF, family = "SF Mono" }
            }
        }
        // Badge — absolute, top-right of the 60×60 box
        frame badge {
            width = 20, height = 20, radius = 999, fill = #CF222E
            stroke = [2, #FFFFFF]
            layout = horizontal, justify = center, align = center
            text count { size = 11, weight = semibold, color = #FFFFFF }
            position = absolute, top = -2, left = 42
        }
    }
}

// ── Chip (官方 / 机器人 / 外部) ─────────────────────────────────────
component chip(label, bg, color) {
    frame {
        padding = [2, 6], radius = 4, fill = bg
        layout = horizontal, justify = center, align = center
        text label { size = 11, weight = medium, color = color }
    }
}

// ── Channel cell variants ──────────────────────────────────────────
// Body row 1: title + (optional chip) + spacer + time
// Body row 2: preview text

// Plain cell (no chip, no badge)
component ch_cell(av_content, av_bg, name, preview, time) {
    frame {
        width = fill, height = 76, padding = [12, 16]
        fill = #FFFFFF
        layout = horizontal, gap = 12, align = center

        use avatar(av_content, av_bg)
        frame body { layout = vertical, gap = 4, width = 280
            frame row1 {
                width = fill, layout = horizontal, gap = 6, align = center
                text name { size = 17, weight = semibold, color = #1F2328 }
                frame spacer { width = fill }
                text time { size = 12, color = #8E8E93 }
            }
            text preview { size = 13, color = #8E8E93, wrap = false }
        }
    }
}

// With chip
component ch_cell_chip(av_content, av_bg, name, chip_label, chip_bg, chip_color, preview, time) {
    frame {
        width = fill, height = 76, padding = [12, 16]
        fill = #FFFFFF
        layout = horizontal, gap = 12, align = center

        use avatar(av_content, av_bg)
        frame body { layout = vertical, gap = 4, width = 280
            frame row1 {
                width = fill, layout = horizontal, gap = 6, align = center
                text name { size = 17, weight = semibold, color = #1F2328 }
                use chip(chip_label, chip_bg, chip_color)
                frame spacer { width = fill }
                text time { size = 12, color = #8E8E93 }
            }
            text preview { size = 13, color = #8E8E93, wrap = false }
        }
    }
}

// With unread badge (top-right of avatar)
component ch_cell_unread(av_content, av_bg, count, name, chip_label, chip_bg, chip_color, preview, time) {
    frame {
        width = fill, height = 76, padding = [12, 16]
        fill = #FFFFFF
        layout = horizontal, gap = 8, align = center

        use avatar_with_badge(av_content, av_bg, count)
        frame body { layout = vertical, gap = 4, width = 280
            frame row1 {
                width = fill, layout = horizontal, gap = 6, align = center
                text name { size = 17, weight = semibold, color = #1F2328 }
                use chip(chip_label, chip_bg, chip_color)
                frame spacer { width = fill }
                text time { size = 12, color = #8E8E93 }
            }
            text preview { size = 13, color = #8E8E93, wrap = false }
        }
    }
}

// Outline-style avatar variant (white bg, colored stroke + letter)
component ch_cell_outline(letter, av_bg, av_color, name, preview, time) {
    frame {
        width = fill, height = 76, padding = [12, 16]
        fill = #FFFFFF
        layout = horizontal, gap = 12, align = center

        use avatar_outline(letter, av_bg, av_color)
        frame body { layout = vertical, gap = 4, width = 280
            frame row1 {
                width = fill, layout = horizontal, gap = 6, align = center
                text name { size = 17, weight = semibold, color = #1F2328 }
                frame spacer { width = fill }
                text time { size = 12, color = #8E8E93 }
            }
            text preview { size = 13, color = #8E8E93, wrap = false }
        }
    }
}

// Top reminder banner (Lark "明天 14:00 - 18:00" pattern)
component banner_row() {
    frame {
        width = fill, height = 76, padding = [12, 16]
        fill = #F2F2F7
        layout = horizontal, gap = 12, align = center

        use avatar_emoji("🔔", #FB923C)
        frame body { layout = vertical, gap = 4, width = 320
            frame row1 {
                width = fill, layout = horizontal, gap = 6, align = center
                text "Reminder" { size = 17, weight = semibold, color = #1F2328 }
                frame spacer { width = fill }
            }
            text "Tomorrow 14:00 — Architecture review w/ Maria" { size = 13, color = #8E8E93, wrap = false }
        }
    }
}

component pg_channels_list() {
frame root {
    width = 393, height = 852, fill = #FFFFFF
    radius = 47, stroke = [3, #1F2328]
    layout = vertical

    use sh_status_bar()
    use sh_nav_bar()

    frame list {
        width = fill, height = fill, fill = #FFFFFF
        padding = [0, 0, 88, 0], layout = vertical, gap = 0

        use banner_row()

        // Unread w/ chip (sample: 3 unread)
        use ch_cell_unread("#", #0969DA, "3",
            "auth-review", "Linked", #DDF4FF, #0550AE,
            "pod-def-456: designing JWT-based...", "now")

        // Unread, no chip
        use ch_cell_unread("#", #1A7F37, "1",
            "dev-pair-programming", "Linked", #DDF4FF, #0550AE,
            "Maria: Can you check the schema?", "2m")

        // Plain cell w/ chip
        use ch_cell_chip("#", #9A6700,
            "ticket-dev-2", "Linked", #DDF4FF, #0550AE,
            "system: 2 pods joined", "8m")

        // Plain cells (read)
        use ch_cell("#", #6F42C1, "demo-api-backend",
            "Maria: New PR opened on #142", "1h")
        use ch_cell("#", #BF8700, "standups",
            "Sam: Shipping DEV-4 today", "3h")

        // Outline-style cells (low-priority / quiet)
        use ch_cell_outline("D", #FFFFFF, #1A7F37, "design-crits",
            "no recent messages", "4d")
        use ch_cell_outline("O", #FFFFFF, #6F42C1, "ops",
            "no recent messages", "1w")
    }

    frame tab_zone {
        width = fill, height = 88, fill = #FFFFFF
        layout = vertical, justify = end, align = center, padding = [0, 0, 16, 0]
        use sh_floating_tab_bar()
    }

    frame safe_bottom { width = fill, height = 34, fill = #FFFFFF
        layout = horizontal, justify = center, align = center
        shape ind { type = rectangle, width = 134, height = 5, radius = 999, fill = #1F2328 }
    }
}
}


component pg_channels_list_framed() {
    frame outer {
        width = 1100, height = 1100, fill = #1F2328
        padding = [60, 80], layout = horizontal, justify = center, align = center
        use pg_channels_list()
    }
}

frame root { use pg_channels_list_framed() }
