// iOS Block detail — read-only push view.

asset back_blue = image("../assets/lucide-png/back-0969DA.png")
asset more_blue = image("../assets/lucide-png/ellipsis-0969DA.png")

canvas "ios_block_detail" {
    width = 1100
    height = 1100
    background = #1F2328
}

component sh_status_bar() {
    frame {
        width = fill, height = 59, fill = #FFFFFF
        layout = horizontal, justify = space-between, align = center, padding = [0, 22]
        text "9:41" { size = 17, weight = semibold, color = #1F2328, family = "SF Pro" }
        frame icons { layout = horizontal, gap = 6, align = center
            text "📶" { size = 14 } text "📡" { size = 14 }
            frame battery { width = 28, height = 13, radius = 4, stroke = [1, #1F2328], padding = 2,
                layout = horizontal, align = center
                shape level { type = rectangle, width = 20, height = 7, radius = 1, fill = #1F2328 }
            }
        }
    }
}

component sh_nav_push() {
    frame {
        width = fill, height = 56, fill = #FFFFFFE6
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        frame back { layout = horizontal, gap = 0, align = center
            frame back_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image back_blue { width = 24, height = 24 }
            }
            frame title_block { layout = vertical, gap = 0
                text "engineering/auth" { size = 11, color = #8E8E93, family = "SF Mono" }
                text "Auth Architecture" { size = 17, weight = semibold, color = #1F2328 }
            }
        }
        frame more_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
            image more_blue { width = 24, height = 24 }
        }
    }
}

component md_h1(t) { text t { size = 28, weight = semibold, color = #1F2328 } }
component md_h2(t) { text t { size = 22, weight = semibold, color = #1F2328 } }
component md_p(t)  { text t { size = 17, color = #1F2328, wrap = true, width = 320, line-height = 24 } }
component md_li(t) {
    frame { layout = horizontal, gap = 8, align = start
        text "•" { size = 17, color = #8E8E93 }
        text t { size = 17, color = #1F2328, wrap = true, width = 300, line-height = 24 }
    }
}
component md_code(t) {
    frame { width = fill, padding = 14, radius = 12, fill = #F2F2F7
        text t { size = 13, color = #1F2328, family = "SF Mono", wrap = true, width = 320, line-height = 18 }
    }
}

component pg_block_detail() {
frame root {
    width = 393, height = 852, fill = #FFFFFF
    radius = 47, stroke = [3, #1F2328]
    layout = vertical

    use sh_status_bar()
    use sh_nav_push()

    frame doc {
        width = fill, height = fill, fill = #FFFFFF
        padding = [16, 24, 100, 24], layout = vertical, gap = 16

        frame meta_row {
            layout = horizontal, gap = 8, align = center, padding = [0, 0, 8, 0]
            frame avatar { width = 24, height = 24, radius = 999, fill = #0969DA
                layout = horizontal, justify = center, align = center
                text "M" { size = 11, weight = semibold, color = #FFFFFF }
            }
            text "Maria edited 12 minutes ago" { size = 13, color = #8E8E93 }
        }

        use md_h1("Auth Architecture")
        use md_p("Authentication design for demo-api. Sources: PR #142, ADR-007, security review (2026-04).")

        use md_h2("Core flow")
        use md_li("POST /login → access (15m) + refresh (30d) JWTs")
        use md_li("RS256 signing; private key in HSM signer service")
        use md_li("Public key served via /.well-known/jwks.json")

        use md_h2("Token shape")
        use md_code("{\n  \"sub\": \"user_abc\",\n  \"org\": \"demo-org\",\n  \"role\": \"member\",\n  \"iat\": 1714291200,\n  \"exp\": 1714292100\n}")
    }

    frame edit_hint {
        width = fill, padding = [12, 16, 12, 16]
        fill = #F2F2F7E6, stroke = [1, #E4E9EE]
        layout = horizontal, justify = center, align = center, gap = 8
        text "✏" { size = 15, color = #8E8E93 }
        text "Edit on desktop · iOS is read-only" { size = 14, color = #8E8E93 }
    }

    frame safe_bottom { width = fill, height = 34, fill = #F2F2F7E6
        layout = horizontal, justify = center, align = center
        shape ind { type = rectangle, width = 134, height = 5, radius = 999, fill = #1F2328 }
    }
}
}


component pg_block_detail_framed() {
    frame outer {
        width = 1100, height = 1100, fill = #1F2328
        padding = [60, 80], layout = horizontal, justify = center, align = center
        use pg_block_detail()
    }
}

frame root { use pg_block_detail_framed() }
