// iOS Pods List — alternative list view (grid is the default).
// 393×852pt @1× · floating tab bar · Lark-style nav · #F2F2F7 page bg.

asset search_blue       = image("../assets/lucide-png/search-0969DA.png")
asset plus_blue         = image("../assets/lucide-png/plus-0969DA.png")
asset terminal_active   = image("../assets/lucide-png/terminal-filled-0969DA.png")
asset message_inactive  = image("../assets/lucide-png/message-8E8E93.png")
asset ticket_inactive   = image("../assets/lucide-png/ticket-8E8E93.png")
asset blocks_inactive   = image("../assets/lucide-png/blocks-8E8E93.png")
asset more_inactive     = image("../assets/lucide-png/ellipsis-8E8E93.png")

canvas "ios_pods_list" {
    width = 1100
    height = 1100
    background = #1F2328
}

component sh_status_bar() {
    frame {
        width = fill, height = 59, fill = #FFFFFF
        layout = horizontal, justify = space-between, align = center
        padding = [0, 22]
        text "9:41" { size = 17, weight = semibold, color = #1F2328, family = "SF Pro" }
        frame icons { layout = horizontal, gap = 6, align = center
            text "📶" { size = 14 }
            text "📡" { size = 14 }
            frame battery { width = 28, height = 13, radius = 4, stroke = [1, #1F2328], padding = 2,
                layout = horizontal, align = center
                shape level { type = rectangle, width = 20, height = 7, radius = 1, fill = #1F2328 }
            }
        }
    }
}

component sh_nav_bar(title) {
    frame {
        width = fill, height = 44, fill = #FFFFFFE6
        padding = [0, 8, 0, 12], layout = horizontal, justify = space-between, align = center
        frame left { layout = horizontal, gap = 12, align = center
            frame avatar { width = 40, height = 40, radius = 999, fill = #0969DA
                layout = horizontal, justify = center, align = center
                text "S" { size = 17, weight = semibold, color = #FFFFFF }
            }
            text title { size = 17, weight = semibold, color = #1F2328 }
        }
        frame actions { layout = horizontal, gap = 4, align = center
            frame search_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image search_blue { width = 24, height = 24 }
            }
            frame plus_btn { width = 44, height = 44, layout = horizontal, justify = center, align = center
                image plus_blue { width = 24, height = 24 }
            }
        }
    }
}

component sh_floating_tab_bar() {
    frame {
        width = 361, height = 56, radius = 28
        fill = #FFFFFFE6, stroke = [1, #0000000D]
        shadow = [0, 4, 12, #00000014]
        padding = [0, 8], layout = horizontal, justify = space-between, align = center

        frame t1 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image terminal_active { width = 24, height = 24 }
            text "Pods" { size = 10, weight = semibold, color = #0969DA, family = "SF Pro" }
        }
        frame t2 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image message_inactive { width = 24, height = 24 }
            text "Channels" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t3 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image ticket_inactive { width = 24, height = 24 }
            text "Tickets" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t4 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image blocks_inactive { width = 24, height = 24 }
            text "Blocks" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
        frame t5 { width = 64, layout = vertical, gap = 2, align = center, justify = center, padding = [4, 0]
            image more_inactive { width = 24, height = 24 }
            text "More" { size = 10, weight = medium, color = #8E8E93, family = "SF Pro" }
        }
    }
}

component pod_row(dot_color, agent_letter, agent_bg, pod_key, agent_label, status_text, status_bg, status_color, time) {
    frame {
        width = fill, height = 64, padding = [10, 16]
        fill = #FFFFFF
        layout = horizontal, gap = 12, align = center

        frame agent_icon {
            width = 40, height = 40, radius = 10, fill = agent_bg
            layout = horizontal, justify = center, align = center
            text agent_letter { size = 17, weight = semibold, color = #FFFFFF, family = "SF Mono" }
        }
        frame stack { layout = vertical, gap = 4, width = 248
            frame row1 {
                width = fill, layout = horizontal, justify = space-between, align = center
                text pod_key { size = 15, weight = semibold, color = #1F2328, family = "SF Mono" }
                text time { size = 13, color = #8E8E93 }
            }
            frame row2 {
                width = fill, layout = horizontal, gap = 8, align = center
                text agent_label { size = 13, color = #8E8E93, family = "SF Mono" }
                frame status_chip { padding = [2, 8], radius = 4, fill = status_bg
                    layout = horizontal, gap = 4, align = center
                    frame dot { width = 6, height = 6, radius = 999, fill = dot_color }
                    text status_text { size = 11, weight = medium, color = status_color }
                }
            }
        }
    }
}

component sep() {
    frame { width = fill, height = 1, padding = [0, 0, 0, 68]
        layout = horizontal
        shape line { type = rectangle, width = fill, height = 1, fill = #F2F2F7 }
    }
}

component seg_active(label) {
    frame { padding = [4, 16], radius = 7, fill = #FFFFFF
        stroke = [1, #00000010], shadow = [0, 1, 1, #00000010]
        layout = horizontal, justify = center, align = center
        text label { size = 13, weight = semibold, color = #1F2328 }
    }
}
component seg_inactive(label) {
    frame { padding = [4, 16]
        layout = horizontal, justify = center, align = center
        text label { size = 13, weight = medium, color = #1F2328 }
    }
}

component pg_pods_list() {
frame root {
    width = 393, height = 852, fill = #FFFFFF
    radius = 47, stroke = [3, #1F2328]
    layout = vertical

    use sh_status_bar()
    use sh_nav_bar("Pods")

    frame seg_wrap {
        width = fill, padding = [12, 16, 8, 16], fill = #F2F2F7
        layout = horizontal, justify = center, align = center
        frame seg {
            width = 280, height = 32, padding = 2, radius = 8, fill = #E9E9EB
            layout = horizontal, gap = 0, align = center, justify = space-between
            use seg_active("Mine")
            use seg_inactive("Others")
            use seg_inactive("Completed")
        }
    }

    frame list {
        width = fill, height = fill, fill = #F2F2F7
        padding = [4, 16, 88, 16], layout = vertical, gap = 8

        frame card {
            width = fill, radius = 12, fill = #FFFFFF, layout = vertical
            use pod_row(#3FB950, "C", #3FB950, "pod-abc-123", "claude-code · pty",
                "running",   #DAFBE1, #1A7F37, "2m")
            use sep()
            use pod_row(#0969DA, "X", #58A6FF, "pod-def-456", "codex · acp",
                "executing", #DDF4FF, #0550AE, "8m")
            use sep()
            use pod_row(#D29922, "A", #D29922, "pod-ghi-789", "aider · pty",
                "idle",      #F0F3F6, #656D76, "1h")
            use sep()
            use pod_row(#3FB950, "C", #3FB950, "pod-jkl-000", "claude-code · acp",
                "done",      #DAFBE1, #1A7F37, "3h")
        }
    }

    frame tab_zone {
        width = fill, height = 88, fill = #F2F2F7
        layout = vertical, justify = end, align = center, padding = [0, 0, 16, 0]
        use sh_floating_tab_bar()
    }

    frame safe_bottom { width = fill, height = 34, fill = #F2F2F7
        layout = horizontal, justify = center, align = center
        shape ind { type = rectangle, width = 134, height = 5, radius = 999, fill = #1F2328 }
    }
}
}


component pg_pods_list_framed() {
    frame outer {
        width = 1100, height = 1100, fill = #1F2328
        padding = [60, 80], layout = horizontal, justify = center, align = center
        use pg_pods_list()
    }
}

frame root { use pg_pods_list_framed() }
