load("@aspect_rules_js//npm:defs.bzl", "npm_package")

# wasm-pack output directory shipped as an npm_package. The
# `package = "agentsmesh-wasm"` attr lets the root BUILD.bazel link it
# via `npm_link_package` (replacing the previous `file:clients/core/pkg`
# entry in root package.json which we removed when going pure-Bazel
# for first-party deps). Bazel-native producer is
# `//clients/core/crates/wasm:wasm_pkg` (Phase 3a TODO; needs wasm32
# Rust toolchain) — until that lands the .wasm/.js outputs are
# checked in alongside the source-tree wasm-pack-generated package.json.
npm_package(
    name = "pkg",
    srcs = ["package.json"] + glob(
        [
            "*.ts",
            "*.js",
            "*.wasm",
        ],
        allow_empty = True,
    ),
    package = "agentsmesh-wasm",
    version = "0.1.0",
    visibility = ["//visibility:public"],
)
