load("@aspect_rules_js//npm:defs.bzl", "npm_package")

# Legacy wasm-pack output directory — pnpm-lock references it as
# `agentsmesh-wasm@file:clients/core/pkg`. Under Bazel the real producer
# is `//clients/core/crates/wasm:wasm_pkg` (Phase 3a), but we still need
# an npm_package target at this path so pnpm workspace link resolution
# can find it until the legacy file: dep is removed.
npm_package(
    name = "pkg",
    srcs = ["package.json"] + glob(
        [
            "*.ts",
            "*.js",
            "*.wasm",
        ],
        allow_empty = True,
    ),
    visibility = ["//visibility:public"],
)
