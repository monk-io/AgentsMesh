load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

# Relay binary protocol (TLV framing used between web/desktop/iOS and the
# runner over WebSocket). Intentionally kept tiny and free of async deps
# so it compiles cleanly for both native and wasm32 targets.
rust_library(
    name = "protocol",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "agentsmesh_protocol",
    edition = "2021",
    visibility = ["//clients/core:__subpackages__"],
    deps = [
        "@crates//:bytes",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:thiserror",
    ],
)

rust_test(
    name = "protocol_test",
    crate = ":protocol",
    edition = "2021",
)
