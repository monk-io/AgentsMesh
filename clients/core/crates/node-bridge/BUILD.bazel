load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@aspect_rules_js//npm:defs.bzl", "npm_package")
load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")
load("//build_defs/rust:napi.bzl", "napi_rust_library")

# NAPI layer — Electron's main process loads this as a `.node` addon.
# The rust_library compiles as a cdylib; napi_rust_library renames
# the platform-specific dylib suffix (`.dylib`/`.so`/`.dll`) → `.node`.
rust_library(
    name = "node_bridge_lib",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "agentsmesh_node_bridge",
    edition = "2021",
    proc_macro_deps = [
        "@crates//:napi-derive",
    ],
    visibility = ["//clients/core:__subpackages__"],
    deps = [
        "//clients/core/crates/api-client:api_client",
        "//clients/core/crates/auth",
        "//clients/core/crates/services",
        "//clients/core/crates/state",
        "//clients/core/crates/types",
        "@crates//:dirs",
        "@crates//:napi",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:tokio",
    ],
)

rust_test(
    name = "node_bridge_test",
    crate = ":node_bridge_lib",
    edition = "2021",
)

napi_rust_library(
    name = "node_bridge",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "agentsmesh_node_bridge",
    proc_macro_deps = [
        "@crates//:napi-derive",
    ],
    deps = [
        "//clients/core/crates/api-client:api_client",
        "//clients/core/crates/auth",
        "//clients/core/crates/services",
        "//clients/core/crates/state",
        "//clients/core/crates/types",
        "@crates//:dirs",
        "@crates//:napi",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:tokio",
    ],
    visibility = ["//clients/desktop:__subpackages__"],
)

# npm package wrapping the .node addon so pnpm's
# `@agentsmesh/node-bridge: workspace:*` link resolves under Bazel.
#
# Uses the pre-built `.node` binary (from `pnpm -C clients/desktop build`)
# instead of the Bazel-side `:node_bridge` target, because compiling the
# Rust cdylib inside the sandbox requires Node/napi headers that we
# haven't plumbed through. Downstream targets (clients/desktop Electron
# e2e) import this via `:node_modules/@agentsmesh/node-bridge`, which
# transparently surfaces the pre-built artifact.
npm_package(
    name = "pkg",
    srcs = glob(
        [
            "*.node",
            "index.js",
            "index.d.ts",
        ],
        allow_empty = True,
    ) + ["package.json"],
    visibility = ["//visibility:public"],
)

# Prebuilt napi artifacts — shipped as Bazel data so downstream targets
# (e.g. Electron e2e) can consume them without triggering a Bazel-side
# `rust_shared_library` compile that needs Node headers the sandbox
# doesn't have. The `.node` binary is produced by `napi build` outside
# Bazel (via `pnpm -C clients/desktop build`).
js_library(
    name = "prebuilt_addon",
    srcs = glob(
        [
            "*.node",
            "index.js",
            "index.d.ts",
        ],
        allow_empty = True,
    ) + ["package.json"],
    visibility = ["//visibility:public"],
)
