load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")
load("//build_defs/ios:rust_xcframework.bzl", "rust_xcframework")

# FFI layer — Rust-facing library + the iOS XCFramework assembly target.
#
# The library target compiles as a staticlib so it can land inside an
# XCFramework. The Swift + Kotlin bindings are generated from uniffi's
# proc-macros during compilation; running the `rust_xcframework` macro
# below materializes them into a consumable XCFramework.
rust_library(
    name = "ffi",
    srcs = glob(["src/**/*.rs"]),
    crate_features = ["staticlib"],
    crate_name = "agentsmesh_ffi",
    edition = "2021",
    visibility = ["//clients/core:__subpackages__"],
    deps = [
        "//clients/core/crates/api-client:api_client",
        "//clients/core/crates/auth",
        "//clients/core/crates/protocol",
        "//clients/core/crates/services",
        "//clients/core/crates/types",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:thiserror",
        "@crates//:tokio",
        "@crates//:uniffi",
    ],
)

rust_test(
    name = "ffi_test",
    crate = ":ffi",
    edition = "2021",
    # Compiles only on Apple hosts: uniffi's `export` proc-macro emits
    # platform-specific extern bindings that trip up the Linux Rust
    # stdlib surface we build against in CI. The iOS-xcframework job
    # (macOS runner) exercises this crate indirectly via cargo.
    tags = ["manual"],
    target_compatible_with = ["@platforms//os:macos"],
)

# Phase 3b — produce `AgentsMeshCore.xcframework` via the shell-script
# wrapper exposed as a Bazel sh_binary. CI + local dev both invoke:
#   bazel run //clients/core/crates/ffi:AgentsMeshCore
# which delegates to clients/core/scripts/build-ios-xcframework.sh.
# A pure-Bazel replacement (rules_apple apple_static_xcframework +
# rules_rust per-platform transitions + uniffi-bindgen-swift aspect)
# is the long-term target; see rust_xcframework.bzl's module doc.
rust_xcframework(
    name = "AgentsMeshCore",
    visibility = ["//clients/ios:__subpackages__"],
)
