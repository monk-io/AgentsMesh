load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

# Entity events WebSocket client. Uses futures::channel::mpsc + parking_lot::RwLock
# (runtime-agnostic, wasm-friendly); time/spawn go through transport's Runtime
# abstraction. Tokio remains as a test-only dep for #[tokio::test].
rust_library(
    name = "events",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "agentsmesh_events",
    edition = "2021",
    visibility = ["//clients/core:__subpackages__"],
    deps = [
        "//clients/core/crates/api-client:api_client",
        "//clients/core/crates/transport",
        "//clients/core/crates/types",
        "@crates//:futures",
        "@crates//:futures-channel",
        "@crates//:parking_lot",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:thiserror",
        "@crates//:tracing",
        "@crates//:web-time",
    ],
)

rust_test(
    name = "events_test",
    crate = ":events",
    edition = "2021",
    deps = [
        "@crates//:tokio",
    ],
)
