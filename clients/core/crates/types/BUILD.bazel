load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

# Foundational domain types shared across every crate in `clients/core`.
# No network / no serde_json::Value at the public API layer — just plain
# `#[derive(Serialize, Deserialize)]` structs and enums.
#
# As of the Connect-RPC migration the crate also hosts `prost::Message` DTOs
# for migrated services (e.g. `extension_proto.rs`). Those are zero-serde,
# binary-wire-only (conventions §2.5, §3) and live in separate `*_proto.rs`
# files so the legacy serde structs and the prost mirrors stay clearly
# separated during the dual-track migration.

# `*_proto.rs` files are exported so the proto package BUILD.bazel files
# can pair them with `validate_prost_tags` rules (watch list #8).
exports_files(
    glob(["src/*_proto.rs"]),
    visibility = ["//proto:__subpackages__"],
)

rust_library(
    name = "types",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "agentsmesh_types",
    edition = "2021",
    visibility = ["//clients/core:__subpackages__"],
    deps = [
        # R1: auto-generated prost mirrors replace hand-written *_proto.rs.
        # Re-exported via `pub mod proto_billing_v1 { ... }` etc. in lib.rs
        # to preserve the legacy import path.
        "//proto/billing/v1:billing_rust_proto",
        "@crates//:prost",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)

# `cargo test`-equivalent. The types crate has no dev-only deps.
rust_test(
    name = "types_test",
    crate = ":types",
    edition = "2021",
)
