load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

# HTTP API client (wraps reqwest + auth-aware request building). Has two
# compile flavors — native uses rustls-tls, wasm32 uses reqwest's fetch
# backend. The conditional dep is handled inside the crate via `cfg`.
rust_library(
    name = "api_client",
    srcs = glob(["src/**/*.rs"]),
    crate_name = "agentsmesh_api_client",
    edition = "2021",
    visibility = ["//clients/core:__subpackages__"],
    deps = [
        "//clients/core/crates/types",
        "@crates//:futures",
        "@crates//:futures-util",
        "@crates//:reqwest",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:thiserror",
        "@crates//:tokio",
        "@crates//:tracing",
        "@crates//:urlencoding",
    ],
)

rust_test(
    name = "api_client_test",
    crate = ":api_client",
    edition = "2021",
    deps = [
        "@crates//:tokio-test",
        "@crates//:wiremock",
    ],
)
