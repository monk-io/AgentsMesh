load("@aspect_rules_js//js:defs.bzl", "js_library")
load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//build_defs/web:next.bzl", "next_app")
load("//build_defs/web:next_oci.bzl", "next_oci_image")

npm_link_all_packages(name = "node_modules")

ts_project(
    name = "src",
    srcs = glob(
        [
            "src/**/*.ts",
            "src/**/*.tsx",
        ],
        exclude = [
            "src/**/*.test.ts",
            "src/**/*.test.tsx",
        ],
    ),
    declaration = True,
    tsconfig = "tsconfig.json",
    deps = [":node_modules"],
)

next_app(
    name = "next",
    srcs = [":src"],
    data = [
        "next.config.ts",
        "package.json",
        "postcss.config.mjs",
        "tsconfig.json",
        ":node_modules",
    ],
    next_js_binary = ":node_modules/next/package:next_bin",
)

next_oci_image(
    name = "image",
    exposed_ports = ["3000/tcp"],
    repository = "registry.corp.agentsmesh.ai/web-admin",
    start_binary = ":next_start_binary",
)

js_library(
    name = "web_admin",
    srcs = [":next"],
    visibility = ["//visibility:public"],
)
