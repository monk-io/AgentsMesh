# =============================================================================
# AgentsMesh Web Admin 环境变量配置
# =============================================================================

# =============================================================================
# Unified Domain Configuration - Single Source of Truth
# API URL 自动从这两个变量派生（与 Backend/Relay/Web 统一）
# =============================================================================

# 主域名 (e.g., "localhost:10000" 或 "agentsmesh.ai")
PRIMARY_DOMAIN=localhost:10000

# 是否使用 HTTPS (true/false)
USE_HTTPS=false

# =============================================================================
# 传统配置方式（向后兼容，优先级高于 PRIMARY_DOMAIN）
# =============================================================================

# API 基础 URL
# NEXT_PUBLIC_API_URL=http://localhost:10000

# =============================================================================
# OAuth 配置（可选）
# =============================================================================

# GitLab SSO URL (for admin login)
NEXT_PUBLIC_GITLAB_SSO_URL=https://gitlab.com
