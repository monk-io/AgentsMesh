load("@build_bazel_rules_swift//swift:swift.bzl", "swift_library")

# Swift façade over the Rust-backed XCFramework. Consumers import this
# target (`@AgentsMeshCore`); the underlying Clang module + static lib
# are exposed via `:AgentsMeshCore_cc` (a swift_clang_module wrapper that
# provides CcInfo so swift_library can depend on it).
swift_library(
    name = "AgentsMeshCore",
    srcs = glob(["Sources/AgentsMeshCore/*.swift"]) + [
        "//clients/core/crates/ffi:AgentsMeshCore_swift",
    ],
    module_name = "AgentsMeshCore",
    visibility = ["//clients/ios:__subpackages__"],
    deps = [
        "//clients/core/crates/ffi:AgentsMeshCore_cc",
    ],
)
