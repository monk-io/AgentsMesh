load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "terminal",
    srcs = [
        "interface.go",
        "terminal.go",
        "terminal_accessors.go",
        "terminal_io.go",
        "terminal_pty.go",
        "terminal_pty_unix.go",
        "terminal_pty_windows.go",
        "terminal_resize.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/runner/internal/terminal",
    visibility = ["//runner:__subpackages__"],
    deps = [
        "//runner/internal/config",
        "//runner/internal/envfilter",
        "//runner/internal/logger",
        "//runner/internal/safego",
        "@org_golang_x_term//:term",
    ] + select({
        "@rules_go//go/platform:aix": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:android": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:darwin": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:dragonfly": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:freebsd": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:illumos": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:ios": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:js": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:linux": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:netbsd": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:openbsd": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:osx": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:plan9": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:qnx": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:solaris": [
            "@com_github_creack_pty//:pty",
        ],
        "@rules_go//go/platform:windows": [
            "//runner/internal/process",
            "@com_github_userexistserror_conpty//:conpty",
        ],
        "//conditions:default": [],
    }),
)

alias(
    name = "go_default_library",
    actual = ":terminal",
    visibility = ["//runner:__subpackages__"],
)

go_test(
    name = "terminal_test",
    srcs = [
        "terminal_handler_test.go",
        "terminal_pty_test.go",
        "terminal_struct_test.go",
    ],
    embed = [":terminal"],
    deps = ["//runner/internal/testutil"],
)
