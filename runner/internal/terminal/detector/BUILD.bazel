        "multi_signal_detector_test.go",
        "output_activity_detector_test.go",
        "prompt_detector_test.go",
    ],
    embed = [":detector"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
