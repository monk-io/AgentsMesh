load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "detector",
    srcs = [
        "agent_state.go",
        "detector_test_helper.go",
        "multi_signal_confidence.go",
        "multi_signal_config.go",
        "multi_signal_detector.go",
        "multi_signal_notify.go",
        "multi_signal_screen.go",
        "output_activity_detector.go",
        "prompt_detector.go",
        "prompt_patterns.go",
        "state_detector.go",
