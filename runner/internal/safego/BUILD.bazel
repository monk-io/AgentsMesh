load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "safego",
    srcs = ["safego.go"],
    importpath = "github.com/anthropics/agentsmesh/runner/internal/safego",
    visibility = ["//runner:__subpackages__"],
    deps = ["//runner/internal/logger"],
)

alias(
    name = "go_default_library",
    actual = ":safego",
    visibility = ["//runner:__subpackages__"],
)

go_test(
    name = "safego_test",
    srcs = ["safego_test.go"],
    embed = [":safego"],
)
