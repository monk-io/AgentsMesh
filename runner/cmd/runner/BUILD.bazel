load("@rules_go//go:def.bzl", "go_binary", "go_library")
load("//build_defs/docker:go_oci_image.bzl", "go_oci_image")

go_library(
    name = "runner_lib",
    srcs = [
        "cmd_reactivate.go",
        "cmd_register.go",
        "cmd_run.go",
        "cmd_update_endpoint.go",
        "exec_restart.go",
        "exec_restart_windows.go",
        "main.go",
        "register.go",
        "service.go",
        "update.go",
        "webconsole.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/runner/cmd/runner",
    visibility = ["//visibility:private"],
    deps = [
        "//runner/internal/client",
        "//runner/internal/config",
        "//runner/internal/console",
        "//runner/internal/envpath",
        "//runner/internal/lifecycle",
        "//runner/internal/logger",
        "//runner/internal/mcp",
        "//runner/internal/otel",
        "//runner/internal/pidfile",
        "//runner/internal/poddaemon",
        "//runner/internal/runner",
        "//runner/internal/service",
        "//runner/internal/updater",
        "@com_github_kardianos_service//:service",
        "@in_gopkg_yaml_v3//:yaml_v3",
    ],
)

go_binary(
    name = "runner",
    embed = [":runner_lib"],
    visibility = ["//visibility:public"],
)

# Distroless OCI image for the runner daemon. See
# //build_defs/docker:go_oci_image for the macro.
go_oci_image(
    name = "image",
    binary = ":runner",
    repositories = {
        "agentsmesh": "registry.agentsmesh.ai/agentsmesh/runner",
        "corp": "registry.corp.agentsmesh.ai/agentsmesh/runner",
        "dockerhub": "agentsmesh/runner",
    },
)
