load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "demo-api_lib",
    srcs = ["main.go"],
    importpath = "github.com/anthropics/agentsmesh/deploy/dev/gitea/repos/demo-api",
    visibility = ["//visibility:private"],
)

go_binary(
    name = "demo-api",
    embed = [":demo-api_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "demo-api_test",
    srcs = ["main_test.go"],
    embed = [":demo-api_lib"],
)
